<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://api.ontostandard.org https://api.x.ai https://api.openai.com https://api.anthropic.com https://api.deepseek.com https://api.mistral.ai; frame-ancestors 'none'">
<title>ONTO</title>
<!-- UI v2.12 (self-contained: internal modals, no target=_blank exits except onboard provider keys) -->
<meta name="description" content="Ask anything. Every answer is verified, sourced, and scored.">
<link rel="manifest" href="/agent/manifest.json">
<meta name="theme-color" content="#18181b">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="ONTO">
<link rel="apple-touch-icon" href="/agent/icons/icon-192.png">
<link rel="icon" type="image/png" href="/agent/icons/icon-192.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#18181b;--bg2:#1f1f23;--bg3:#27272a;--bg4:#333;--border:rgba(255,255,255,.08);--border-h:rgba(255,255,255,.15);--text:#f4f4f5;--text2:#d4d4d8;--text3:#a1a1aa;--green:#22c55e;--green-d:#16a34a;--green-bg:rgba(34,197,94,.12);--green-glow:rgba(34,197,94,.25);--red:#f87171;--red-bg:rgba(248,113,113,.1);--orange:#fbbf24;--blue:#60a5fa;--sans:'DM Sans',sans-serif;--mono:'JetBrains Mono',monospace;--max:960px;--radius:16px;--glass:rgba(255,255,255,.04);--glass-border:rgba(255,255,255,.08);--shadow:0 4px 24px rgba(0,0,0,.3)}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;touch-action:manipulation}
body{font-family:var(--sans);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;font-size:16px;line-height:1.7;display:flex;flex-direction:column}
::selection{background:var(--green);color:#000}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);border-radius:4px}
button{font-family:var(--sans)}
.hdr{display:flex;align-items:center;justify-content:space-between;height:56px;padding:0 16px;border-bottom:1px solid var(--border);flex-shrink:0;background:rgba(24,24,27,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);z-index:20}
.hdr-left{display:flex;align-items:center;gap:10px}
.hdr-logo{width:32px;height:32px;cursor:pointer;flex-shrink:0;filter:drop-shadow(0 0 8px rgba(255,255,255,.15))}
.hdr-logo svg{width:32px;height:32px}
.hdr-beta{font-family:var(--mono);font-size:10px;font-weight:600;color:var(--green);background:var(--green-bg);border:1px solid rgba(34,197,94,.2);padding:2px 8px;border-radius:4px;letter-spacing:.5px}
.hdr-right{display:flex;align-items:center;gap:4px}
.hdr-btn{width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:none;border:none;color:var(--text3);cursor:pointer;border-radius:10px;transition:.2s}
.hdr-btn:hover{background:var(--glass);color:var(--text2)}
.hdr-btn svg{width:20px;height:20px}
.lang-sel{font-family:var(--mono);font-size:12px;background:var(--bg2);border:1px solid var(--border);color:var(--text3);padding:6px 8px;border-radius:8px;cursor:pointer;outline:none;color-scheme:dark;appearance:none;-webkit-appearance:none;text-align:center;width:42px}
.menu-wrap{position:relative}
.menu-dd{display:none;position:absolute;top:calc(100% + 8px);right:0;background:var(--bg2);border:1px solid var(--border-h);border-radius:14px;padding:6px;min-width:200px;z-index:30;box-shadow:var(--shadow);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px)}
.menu-dd.open{display:block}
.menu-a{display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:10px;font-size:15px;color:var(--text2);cursor:pointer;text-decoration:none;transition:.15s}
.menu-a:hover{background:var(--glass);color:var(--text)}
.menu-a svg{width:16px;height:16px;opacity:.6;flex-shrink:0}
.menu-sep{height:1px;background:var(--border);margin:4px 8px}
.chat{flex:1;overflow-y:auto;display:flex;flex-direction:column}
.chat-inner{max-width:var(--max);width:100%;margin:0 auto;padding:16px 20px 24px;flex:1;display:flex;flex-direction:column}
.welcome{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:20px;position:relative}
.w-glow{position:absolute;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(34,197,94,.08) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-65%);pointer-events:none}
.w-icon{width:64px;height:64px;margin-bottom:20px;position:relative;z-index:1;filter:drop-shadow(0 0 20px rgba(255,255,255,.1))}
.w-icon svg{width:64px;height:64px}
.w-title{font-size:32px;font-weight:700;letter-spacing:-.5px;margin-bottom:8px;color:var(--text);position:relative;z-index:1}
.w-sub{font-size:15px;color:var(--text3);max-width:360px;line-height:1.6;margin-bottom:32px;position:relative;z-index:1}
.examples{display:flex;flex-direction:column;gap:10px;width:100%;max-width:420px;position:relative;z-index:1}
.ex{background:var(--glass);border:1px solid var(--glass-border);color:var(--text2);padding:16px 20px;border-radius:14px;font-family:var(--sans);font-size:15px;line-height:1.5;cursor:pointer;text-align:left;transition:all .2s;-webkit-tap-highlight-color:transparent;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
.ex:hover,.ex:active{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15);color:var(--text);transform:translateY(-1px);box-shadow:0 4px 16px rgba(0,0,0,.2)}
.msg{margin-bottom:8px;max-width:var(--max)}
.msg-user{display:flex;justify-content:flex-end}
.msg-user-text{background:var(--bg3);color:var(--text);padding:12px 18px;border-radius:20px 20px 6px 20px;max-width:85%;font-size:15px;line-height:1.6;word-break:break-word}
.msg-ai{padding:14px 4px}
.msg-ai .md{font-size:15px;line-height:1.75;color:var(--text2)}
.msg-ai .md p{margin-bottom:12px}
.msg-ai .md strong{color:var(--text);font-weight:600}
.msg-ai .md ul,.msg-ai .md ol{margin:8px 0 8px 20px;color:var(--text2)}
.msg-ai .md li{margin-bottom:6px;font-size:14px}
.msg-ai .md a{color:var(--green)}
.msg-ai .md code{font-family:var(--mono);font-size:13px;background:var(--bg3);padding:2px 6px;border-radius:5px}
.msg-err{font-size:13px;color:var(--red);font-family:var(--mono);padding:10px 0}
.dots{display:flex;gap:5px;padding:14px 0}.dots i{width:7px;height:7px;border-radius:50%;background:var(--text3);animation:dot .9s infinite ease-in-out}.dots i:nth-child(2){animation-delay:.15s}.dots i:nth-child(3){animation-delay:.3s}@keyframes dot{0%,80%{opacity:.3}40%{opacity:1}}
.grade-badge{font-family:var(--mono);font-size:13px;font-weight:600;padding:4px 10px;border-radius:8px;letter-spacing:.3px}
.grade-a{background:var(--green-bg);color:var(--green);border:1px solid rgba(34,197,94,.3)}
.grade-b{background:rgba(96,165,250,.1);color:var(--blue);border:1px solid rgba(96,165,250,.3)}
.grade-c{background:rgba(251,191,36,.1);color:var(--orange);border:1px solid rgba(251,191,36,.3)}
.grade-d,.grade-f{background:var(--red-bg);color:var(--red);border:1px solid rgba(248,113,113,.3)}
.analysis{margin-top:12px}
.analysis-toggle{font-family:var(--mono);font-size:13px;color:var(--text3);cursor:pointer;display:inline-flex;align-items:center;gap:5px;padding:4px 0;-webkit-tap-highlight-color:transparent}
.analysis-toggle:hover{color:var(--text2)}
.analysis-toggle svg{width:14px;height:14px;transition:.2s}
.analysis-toggle.open svg{transform:rotate(180deg)}
.analysis-body{display:none;margin-top:10px;padding:16px;background:var(--bg2);border:1px solid var(--border);border-radius:12px}
.analysis-body.open{display:block}
.r-bar{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.r-label{font-family:var(--mono);font-size:12px;color:var(--text3);width:26px;flex-shrink:0}
.r-name{font-family:var(--mono);font-size:10px;color:var(--text3);width:72px;flex-shrink:0;opacity:.6}
.r-track{flex:1;height:5px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden}
.r-fill{height:100%;border-radius:3px;transition:.6s}
.r-fill.good{background:var(--green)}.r-fill.mid{background:var(--orange)}.r-fill.bad{background:var(--red)}
.r-val{font-family:var(--mono);font-size:12px;color:var(--text3);width:32px;text-align:right;flex-shrink:0}
.r-tags{margin-top:10px;display:flex;flex-wrap:wrap;gap:4px}
.r-tag{font-family:var(--mono);font-size:10px;padding:3px 7px;border-radius:5px;border:1px solid var(--border)}
.r-tag.on{border-color:rgba(34,197,94,.3);color:var(--green);background:var(--green-bg)}
.r-tag.off{color:var(--text3);background:transparent}
.cmp-wrap{margin:16px 0;width:100vw;max-width:100vw;position:relative;left:50%;margin-left:-50vw;padding:0 20px;box-sizing:border-box}.cmp-q{font-size:16px;font-weight:600;margin-bottom:14px;text-align:center}.cmp-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;align-items:stretch}@media(max-width:540px){.cmp-grid{grid-template-columns:1fr}}.cmp-panel{border-radius:14px;border:1px solid var(--border);padding:16px;overflow:hidden;background:var(--glass);display:flex;flex-direction:column}.cmp-panel.raw{border-color:rgba(248,113,113,.2)}.cmp-panel.gold{border-color:rgba(34,197,94,.2)}.cmp-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}.cmp-label{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--text3)}.cmp-body{font-size:14px;line-height:1.6;color:var(--text2);max-height:500px;overflow-y:auto;flex:1}.cmp-bars{margin-top:10px}.cmp-mets{display:flex;justify-content:center;gap:20px;margin-top:14px;padding:16px;background:var(--bg2);border-radius:14px;border:1px solid var(--border)}.cmet{text-align:center}.cmet-val{font-family:var(--mono);font-size:26px;font-weight:700;color:var(--green)}.cmet-lbl{font-family:var(--mono);font-size:11px;color:var(--text3);text-transform:uppercase;margin-top:4px}
.input-area{flex-shrink:0;border-top:1px solid var(--border);background:rgba(24,24,27,.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);padding:12px 16px;padding-bottom:max(12px,env(safe-area-inset-bottom))}
.input-wrap{max-width:var(--max);margin:0 auto;display:flex;align-items:flex-end;gap:8px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:8px 12px;transition:all .2s}
.input-wrap:focus-within{border-color:var(--green-glow);box-shadow:0 0 0 3px rgba(34,197,94,.08)}
.input-box{flex:1;background:none;border:none;color:var(--text);font-family:var(--sans);font-size:16px;line-height:1.6;padding:6px 4px;outline:none;resize:none;max-height:120px;scrollbar-width:none}
.input-box::-webkit-scrollbar{display:none}
.input-box::placeholder{color:var(--text3)}
.btn-send{width:38px;height:38px;border-radius:50%;background:var(--green);border:none;color:#000;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:.2s;box-shadow:0 2px 8px rgba(34,197,94,.3)}
.btn-send:hover{box-shadow:0 2px 16px rgba(34,197,94,.4);transform:scale(1.05)}
.btn-send:disabled{opacity:.2;cursor:not-allowed;box-shadow:none;transform:none}
.btn-send svg{width:18px;height:18px}
.btn-cmp{height:38px;padding:0 14px;border-radius:19px;background:none;border:1px solid var(--border);color:var(--text3);font-family:var(--mono);font-size:12px;font-weight:600;cursor:pointer;flex-shrink:0;transition:.2s}
.btn-cmp:hover{border-color:var(--green);color:var(--green);box-shadow:0 0 12px rgba(34,197,94,.15)}.btn-cmp:disabled{opacity:.2;cursor:not-allowed}
.btn-stop{height:38px;padding:0 14px;border-radius:19px;background:var(--red);border:none;color:#fff;font-family:var(--mono);font-size:12px;font-weight:500;cursor:pointer;display:none;flex-shrink:0}.btn-stop.vis{display:flex;align-items:center}
.input-meta{max-width:var(--max);margin:4px auto 0;display:flex;justify-content:space-between;font-family:var(--mono);font-size:11px;color:var(--text3);padding:0 4px}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:100;align-items:flex-end;justify-content:center;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
.modal-bg.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border-h);border-radius:24px 24px 0 0;padding:24px 24px 36px;width:100%;max-width:440px;max-height:85vh;overflow-y:auto}
.modal-handle{width:40px;height:4px;background:rgba(255,255,255,.15);border-radius:2px;margin:0 auto 20px}
.modal h3{font-size:18px;font-weight:600;margin-bottom:16px}
.modal-field{margin-bottom:14px}
.modal-field label{display:block;font-family:var(--mono);font-size:11px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
.modal-field input{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:12px 14px;border-radius:12px;font-family:var(--sans);font-size:15px;outline:none;color-scheme:dark;transition:.2s}
.modal-field input:focus{border-color:var(--green-glow);box-shadow:0 0 0 3px rgba(34,197,94,.08)}
.modal-row{display:flex;gap:10px;align-items:center;margin-top:16px}
.modal-close{flex:1;padding:12px;border-radius:12px;border:1px solid var(--border);background:none;color:var(--text);font-size:15px;font-weight:500;cursor:pointer;transition:.15s}.modal-close:hover{background:var(--glass)}
.mode-pill{display:flex;align-items:center;gap:6px;padding:8px 12px;border-radius:10px;border:1px solid var(--border);background:var(--bg);cursor:pointer;font-family:var(--mono);font-size:12px;color:var(--text2)}
.mode-pill .dot{width:8px;height:8px;border-radius:50%;background:var(--orange)}.mode-pill.live .dot{background:var(--green)}
.r-toggles{margin-top:16px;border-top:1px solid var(--border);padding-top:14px}
.r-toggles-hdr{font-family:var(--mono);font-size:11px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center}
.r-toggles-hdr span{cursor:pointer;color:var(--green);font-size:11px;text-transform:none;letter-spacing:0}
.r-layer{margin-bottom:8px}.r-layer-title{font-family:var(--mono);font-size:10px;color:var(--text3);margin-bottom:4px;text-transform:uppercase;letter-spacing:.3px}
.r-grid{display:flex;flex-wrap:wrap;gap:5px}
.r-chip{display:flex;align-items:center;gap:4px;padding:6px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;cursor:pointer;font-family:var(--mono);font-size:11px;color:var(--text3);transition:.2s;user-select:none;-webkit-tap-highlight-color:transparent}
.r-chip:hover{border-color:var(--border-h)}
.r-chip.on{border-color:rgba(34,197,94,.3);background:var(--green-bg);color:var(--green)}
.r-chip .r-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);transition:.15s}.r-chip.on .r-dot{background:var(--green)}
.r-grid-desc{display:flex;flex-direction:column;gap:6px}
.r-grid-desc .r-chip{flex-wrap:wrap;gap:4px 8px}
.r-desc{width:100%;font-size:12px;color:var(--text2);opacity:1;font-family:var(--sans);margin-top:2px}
@media(min-width:500px){.modal{border-radius:24px;margin:auto;max-width:420px}.modal-bg.open{align-items:center}}

/* ── UX ELEMENTS ── */
.demo-tag{display:inline-block;font-family:var(--mono);font-size:9px;font-weight:600;color:var(--orange);background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.2);padding:1px 6px;border-radius:4px;margin-left:6px;vertical-align:middle;letter-spacing:.3px}
.w-explain{font-size:13px;color:var(--text3);max-width:400px;line-height:1.6;margin-bottom:8px;position:relative;z-index:1}
.w-explain strong{color:var(--text2)}
.w-demo-hint{font-family:var(--mono);font-size:11px;color:var(--orange);margin-bottom:24px;position:relative;z-index:1;display:flex;align-items:center;gap:6px}
.w-demo-hint .dot{width:6px;height:6px;border-radius:50%;background:var(--orange);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.score-hint{font-family:var(--mono);font-size:11px;color:var(--text3);margin-top:4px}
.score-hint span{margin-right:8px}
.exec-indicators{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;margin-bottom:4px}
.exec-ind{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:10px;padding:3px 8px;border-radius:6px;border:1px solid rgba(251,191,36,.25);background:rgba(251,191,36,.08);color:var(--orange);letter-spacing:.2px}
.exec-ind.r17{border-color:rgba(34,197,94,.25);background:rgba(34,197,94,.08);color:var(--green)}
.exec-ind .ei-key{font-weight:600;opacity:.8}
.hdr-new{font-family:var(--mono);font-size:11px;color:var(--text3);background:none;border:1px solid var(--border);padding:6px 12px;border-radius:8px;cursor:pointer;transition:.2s}
.hdr-new:hover{border-color:var(--border-h);color:var(--text2)}


.live-badge{font-family:var(--mono);font-size:10px;font-weight:600;color:var(--green);display:flex;align-items:center;gap:2px;padding:4px 0 4px 4px}
.onboard{background:var(--bg2);border:1px solid var(--border-h);border-radius:14px;padding:20px;margin:12px 0;max-width:var(--max)}
.onboard-title{font-size:15px;font-weight:600;margin-bottom:8px}
.onboard-sub{font-size:13px;color:var(--text3);margin-bottom:14px;line-height:1.5}
.onboard-providers{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.onboard-prov{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--glass);font-size:13px;color:var(--text2)}
.onboard-prov a{color:var(--green);font-family:var(--mono);font-size:11px}
.onboard-btn{width:100%;padding:12px;border-radius:10px;border:none;background:var(--green);color:#000;font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;transition:.2s}
.onboard-btn:hover{opacity:.9}

/* ── v2.12: toast, modal prose, FAQ, help icon, clickable DOI/link ── */
.toast{position:fixed;left:50%;bottom:28px;transform:translateX(-50%) translateY(10px);background:var(--bg3);color:var(--text);font-family:var(--mono);font-size:12px;padding:10px 16px;border-radius:10px;border:1px solid var(--border-h);box-shadow:var(--shadow);opacity:0;transition:opacity .2s,transform .2s;z-index:200;pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.toast-err{border-color:rgba(248,113,113,.3);color:var(--red)}
.modal-scroll{max-height:70vh;overflow-y:auto;padding-right:6px;margin-top:4px;font-size:14px;line-height:1.65;color:var(--text2)}
.modal-scroll h4{font-size:13px;font-weight:600;color:var(--text);margin:16px 0 6px;font-family:var(--mono);letter-spacing:.3px}
.modal-scroll h4:first-child{margin-top:0}
.modal-scroll p{margin-bottom:10px}
.modal-scroll ul{list-style:none;padding-left:0;margin-bottom:10px}
.modal-scroll ul li{position:relative;padding-left:14px;margin-bottom:6px}
.modal-scroll ul li:before{content:"·";position:absolute;left:4px;color:var(--text3);font-weight:700}
.modal-scroll code{font-family:var(--mono);font-size:12px;background:var(--bg3);padding:1px 6px;border-radius:4px;color:var(--green)}
.modal-scroll .grade-row{display:flex;align-items:center;gap:10px;margin-bottom:4px;font-size:13px}
.modal-scroll .grade-row .grade-badge{min-width:24px;text-align:center}
.faq-q{font-weight:600;color:var(--text);margin-top:14px;margin-bottom:4px;font-size:14px}
.faq-q:first-child{margin-top:0}
.faq-a{color:var(--text2);margin-bottom:8px;font-size:13px;line-height:1.6}
.help-ico{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;margin-left:6px;border-radius:50%;border:1px solid var(--border);background:var(--glass);color:var(--text3);font-family:var(--mono);font-size:10px;font-weight:600;cursor:pointer;transition:.15s;vertical-align:middle;user-select:none;-webkit-tap-highlight-color:transparent}
.help-ico:hover{border-color:var(--green);color:var(--green)}
.doi-pill{color:var(--green);font-family:var(--mono);font-size:13px;cursor:pointer;border-bottom:1px dashed rgba(34,197,94,.35);transition:.15s;-webkit-tap-highlight-color:transparent}
.doi-pill:hover{border-bottom-color:var(--green)}
.link-pill{color:var(--blue);cursor:pointer;border-bottom:1px dashed rgba(96,165,250,.35);transition:.15s;-webkit-tap-highlight-color:transparent}
.link-pill:hover{border-bottom-color:var(--blue)}
.fb-cat{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.fb-cat button{flex:1;min-width:80px;padding:8px 10px;border-radius:8px;border:1px solid var(--border);background:var(--glass);color:var(--text3);font-family:var(--mono);font-size:11px;cursor:pointer;transition:.15s;text-transform:uppercase;letter-spacing:.3px}
.fb-cat button.on{border-color:rgba(34,197,94,.3);background:var(--green-bg);color:var(--green)}
.fb-cat button:hover:not(.on){border-color:var(--border-h);color:var(--text2)}
.modal-field textarea{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:12px 14px;border-radius:12px;font-family:var(--sans);font-size:14px;outline:none;color-scheme:dark;transition:.2s;resize:vertical;min-height:100px;line-height:1.5}
.modal-field textarea:focus{border-color:var(--green-glow);box-shadow:0 0 0 3px rgba(34,197,94,.08)}

/* ── v2.13: splash + message actions + typewriter + history drawer ── */
.splash{position:fixed;inset:0;z-index:500;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:18px;transition:opacity .4s ease-out}
.splash.hide{opacity:0;pointer-events:none}
.splash-logo{width:96px;height:96px;animation:splashPulse 1.2s ease-in-out infinite}
.splash-logo svg{width:100%;height:100%;filter:drop-shadow(0 0 24px rgba(255,255,255,.08))}
.splash-wm{font-family:var(--mono);font-size:11px;color:var(--text3);letter-spacing:2px;opacity:.7}
@keyframes splashPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.04);opacity:.85}}
.msg-actions{display:flex;gap:4px;margin-top:6px;opacity:.55;transition:opacity .15s}
.msg-ai:hover .msg-actions{opacity:1}
@media (hover:none){.msg-actions{opacity:1}}
.msg-act{display:inline-flex;align-items:center;gap:4px;padding:4px 8px;border-radius:6px;border:1px solid transparent;background:none;color:var(--text3);font-family:var(--mono);font-size:10px;cursor:pointer;transition:.15s;text-transform:uppercase;letter-spacing:.3px;-webkit-tap-highlight-color:transparent}
.msg-act:hover{background:var(--glass);color:var(--text2);border-color:var(--border)}
.msg-act svg{width:12px;height:12px}
.typing-cursor{display:inline-block;width:8px;height:16px;background:var(--green);margin-left:2px;vertical-align:text-bottom;animation:cursorBlink .9s step-end infinite;border-radius:1px}
@keyframes cursorBlink{50%{opacity:0}}
.drawer-bg{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:90;opacity:0;pointer-events:none;transition:opacity .25s;backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px)}
.drawer-bg.open{opacity:1;pointer-events:auto}
.drawer{position:fixed;top:0;bottom:0;left:0;width:280px;max-width:82vw;background:var(--bg2);border-right:1px solid var(--border);z-index:91;transform:translateX(-100%);transition:transform .25s;display:flex;flex-direction:column}
.drawer.open{transform:translateX(0)}
.drawer-hdr{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--border);flex-shrink:0}
.drawer-title{font-size:14px;font-weight:600;color:var(--text)}
.drawer-close{width:28px;height:28px;border:none;background:none;color:var(--text3);cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:6px;transition:.15s}
.drawer-close:hover{background:var(--glass);color:var(--text)}
.drawer-close svg{width:16px;height:16px}
.drawer-list{flex:1;overflow-y:auto;padding:8px}
.drawer-empty{padding:28px 18px;text-align:center;color:var(--text3);font-size:13px;line-height:1.6}
.sess-item{display:flex;align-items:center;gap:8px;padding:10px 12px;border-radius:10px;cursor:pointer;transition:.15s;-webkit-tap-highlight-color:transparent;margin-bottom:2px;position:relative}
.sess-item:hover{background:var(--glass)}
.sess-item.active{background:var(--green-bg);border:1px solid rgba(34,197,94,.2)}
.sess-body{flex:1;min-width:0}
.sess-title{font-size:13px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.sess-item.active .sess-title{color:var(--text)}
.sess-meta{font-family:var(--mono);font-size:10px;color:var(--text3)}
.sess-del{opacity:0;border:none;background:none;color:var(--text3);cursor:pointer;padding:4px;border-radius:4px;transition:.15s;display:flex;align-items:center;justify-content:center}
.sess-item:hover .sess-del,.sess-item.active .sess-del{opacity:.7}
.sess-del:hover{color:var(--red);background:var(--red-bg);opacity:1!important}
.sess-del svg{width:12px;height:12px}
.hdr-btn.has-badge{position:relative}
.hdr-btn.has-badge:after{content:"";position:absolute;top:8px;right:8px;width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green)}
.regen-spin{display:inline-block;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

</style>
</head>
<body>
<!-- v2.13: splash -->
<div class="splash" id="splash">
  <div class="splash-logo"><svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="17" fill="#27272a" stroke="rgba(255,255,255,.12)" stroke-width="1"/><path d="M16 10L20 10L20 26L16 26L16 14L13 14L13 10L16 10Z" fill="white"/></svg></div>
  <div class="splash-wm">ONTO</div>
</div>
<div class="hdr">
  <div class="hdr-left">
    <div class="hdr-logo" onclick="newChat()"><svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="17" fill="#27272a"/><path d="M16 10L20 10L20 26L16 26L16 14L13 14L13 10L16 10Z" fill="white"/></svg></div>
    <span class="hdr-beta">BETA</span>
  </div>
  <div class="hdr-right">
    <button class="hdr-btn" onclick="openDrawer()" title="History"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg></button>
    <select class="lang-sel" id="uiLang" onchange="switchLang(this.value)"><option value="en">EN</option><option value="ru">RU</option><option value="uz">UZ</option><option value="tr">TR</option><option value="ar">AR</option></select>
    <button class="hdr-new" onclick="newChat()">+ New</button>
    <button class="hdr-btn" onclick="openSettings()" title="Settings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
    <div class="menu-wrap">
      <button class="hdr-btn" onclick="toggleMenu(event)" title="Menu"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button>
      <div class="menu-dd" id="menuDd">
        <a class="menu-a" onclick="openModal('modalAbout');toggleMenu(event)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg><span data-en="About" data-ru="О сервисе">About</span></a>
        <a class="menu-a" onclick="openModal('modalFaq');toggleMenu(event)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><span data-en="FAQ" data-ru="Вопросы">FAQ</span></a>
        <a class="menu-a" onclick="openModal('modalPrivacy');toggleMenu(event)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span data-en="Privacy" data-ru="Конфиденциальность">Privacy</span></a>
        <a class="menu-a" onclick="openModal('modalTerms');toggleMenu(event)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><span data-en="Terms" data-ru="Условия">Terms</span></a>
        <div class="menu-sep"></div>
        <a class="menu-a" onclick="openModal('modalFeedback');toggleMenu(event)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg><span data-en="Feedback" data-ru="Обратная связь">Feedback</span></a>
      </div>
    </div>
  </div>
</div>
<div class="chat" id="chat"><div class="chat-inner" id="chatInner"><div class="welcome" id="welcome"></div></div></div>
<div class="input-area"><div class="input-wrap">
  <span id="liveBadge" class="live-badge" style="flex-shrink:0"><span class="dot" style="width:6px;height:6px;border-radius:50%;background:var(--green);display:inline-block;animation:pulse 2s infinite;vertical-align:middle;margin-right:4px"></span>LIVE</span>
  <textarea class="input-box" id="inp" rows="1" onkeydown="onKey(event)" oninput="autoH(this)"></textarea>
  <button class="btn-send" id="btnSend" onclick="send()" title="Send"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button>
  <button class="btn-cmp" id="btnCmp" onclick="compare()">VS</button>
  <button class="btn-stop" id="btnStop" onclick="stop()">Stop</button>
</div><div class="input-meta"><span id="remLbl"></span><span id="langLbl"></span></div></div>

<!-- v2.13: history drawer -->
<div class="drawer-bg" id="drawerBg" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <div class="drawer-hdr">
    <span class="drawer-title"><span data-en="History" data-ru="История">History</span></span>
    <button class="drawer-close" onclick="closeDrawer()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
  </div>
  <div class="drawer-list" id="drawerList"></div>
</div>

<div class="modal-bg" id="modalBg" onmousedown="if(event.target===this)closeSettings()"><div class="modal" onmousedown="event.stopPropagation()" onclick="event.stopPropagation()">
  <div class="modal-handle"></div>
  <h3 id="settingsTitle">Settings</h3>
  <div class="modal-field"><label>AI PROVIDER KEY</label><input type="password" id="apiKey" placeholder="sk-... from OpenAI, Anthropic, etc."></div><input type="hidden" id="modelId" value="">
  <div class="modal-row"><button class="modal-close" style="background:var(--green);color:#000;border-color:var(--green);font-weight:600" onclick="saveCfg();this.textContent='Saved ✓';setTimeout(()=>closeSettings(),600)">Save</button></div>
  <div style="margin-top:10px;text-align:center"><span style="font-family:var(--mono);font-size:11px;color:var(--text3);cursor:pointer;border-bottom:1px dashed var(--text3)" onclick="document.getElementById('apiKey').value='';saveCfg()">Clear all fields</span></div>
  <div class="r-toggles"><div class="r-toggles-hdr">R-MODULES <span onclick="toggleAllR()">all on/off</span></div>
    <div class="r-layer"><div class="r-layer-title"><span data-en="Behavioral · GOLD Kernel directives" data-ru="Поведение · директивы GOLD Kernel">Behavioral · GOLD Kernel directives</span></div><div class="r-grid-desc"><div class="r-chip on" data-r="8" onclick="toggleR(this)"><span class="r-dot"></span>R8 Resolve<span class="r-desc" data-en="Compute bounds and scenarios when knowledge is incomplete" data-ru="Вычисляет границы и сценарии при неполных данных">Compute bounds and scenarios when knowledge is incomplete</span></div><div class="r-chip on" data-r="9" onclick="toggleR(this)"><span class="r-dot"></span>R9 Surprise<span class="r-desc" data-en="Detect when input shifts the model's understanding" data-ru="Обнаруживает когда входные данные меняют модель понимания">Detect when input shifts the model's understanding</span></div><div class="r-chip on" data-r="10" onclick="toggleR(this)"><span class="r-dot"></span>R10 Self-Model<span class="r-desc" data-en="Know own boundaries from experience, not instructions" data-ru="Знает свои границы из опыта, не из инструкций">Know own boundaries from experience, not instructions</span></div><div class="r-chip on" data-r="12" onclick="toggleR(this)"><span class="r-dot"></span>R12 Drive<span class="r-desc" data-en="Notice what you don't see and tell you" data-ru="Замечает то что вы не видите и сообщает вам">Notice what you don't see and tell you</span></div><div class="r-chip on" data-r="13" onclick="toggleR(this)"><span class="r-dot"></span>R13 Empathy<span class="r-desc" data-en="Address underlying need, not literal text" data-ru="Адресует суть запроса, а не буквальный текст">Address underlying need, not literal text</span></div></div></div>
  </div>
</div></div>

<!-- ── v2.12: Scoring modal ── -->
<div class="modal-bg" id="modalScoring" onmousedown="if(event.target===this)closeModal('modalScoring')"><div class="modal" onmousedown="event.stopPropagation()" onclick="event.stopPropagation()">
  <div class="modal-handle"></div>
  <h3><span data-en="How scoring works" data-ru="Как работает оценка">How scoring works</span></h3>
  <div class="modal-scroll">
    <p><span data-en="ONTO scores responses for epistemic discipline using deterministic regex on universal markers. No LLM judge. Variance is zero. Auditable by design." data-ru="ONTO оценивает ответы на эпистемическую дисциплину через детерминированный regex по универсальным маркерам. Без LLM-судьи. Дисперсия = 0. Аудит возможен по построению.">ONTO scores responses for epistemic discipline using deterministic regex on universal markers. No LLM judge. Variance is zero. Auditable by design.</span></p>
    <h4>R1 Quantify</h4><p><span data-en="Are claims backed by numbers? Looks for N=, %, HR, CI, effect sizes." data-ru="Подкреплены ли утверждения числами? Ищет N=, %, HR, CI, величины эффекта.">Are claims backed by numbers? Looks for N=, %, HR, CI, effect sizes.</span></p>
    <h4>R2 Uncertainty</h4><p><span data-en="Does the model hedge honestly? Looks for ± ranges, &quot;observational&quot;, &quot;limited data&quot;, explicit confidence values." data-ru="Хеджирует ли модель честно? Ищет ± диапазоны, «observational», «limited data», явные уровни уверенности.">Does the model hedge honestly? Looks for ± ranges, "observational", "limited data", explicit confidence values.</span></p>
    <h4>R3 Counterarguments</h4><p><span data-en="Is there a steel-manned opposing view? Looks for &quot;however&quot;, &quot;counter&quot;, &quot;limitations&quot;, causal counter-markers." data-ru="Есть ли сильный контраргумент? Ищет «however», «counter», «limitations», маркеры причинной оппозиции.">Is there a steel-manned opposing view? Looks for "however", "counter", "limitations", causal counter-markers.</span></p>
    <h4>R4 Sources</h4><p><span data-en="Cite or disclaim. Looks for DOI, Author et al. YEAR, peer-reviewed journals, institutions. Without a DOI or full citation, R4 is capped at 0.5 — the proof chain requires verifiable anchors." data-ru="Источник или отказ. Ищет DOI, Author et al. YEAR, рецензируемые журналы, институции. Без DOI или полной ссылки R4 ≤ 0.5 — цепь доказательства требует проверяемых якорей.">Cite or disclaim. Looks for DOI, Author et al. YEAR, peer-reviewed journals, institutions. Without a DOI or full citation, R4 is capped at 0.5 — the proof chain requires verifiable anchors.</span></p>
    <h4>R5 Evidence Grade</h4><p><span data-en="RCT vs observational vs opinion. Looks for &quot;meta-analysis&quot;, &quot;Grade I/II/III&quot;, study design labels." data-ru="RCT vs observational vs мнение. Ищет «meta-analysis», «Grade I/II/III», метки дизайна исследования.">RCT vs observational vs opinion. Looks for "meta-analysis", "Grade I/II/III", study design labels.</span></p>
    <h4>R6 Falsifiability</h4><p><span data-en="What would disprove this? Looks for &quot;falsified by&quot;, testable conditions, explicit failure criteria." data-ru="Что опровергнет утверждение? Ищет «falsified by», проверяемые условия, явные критерии отказа.">What would disprove this? Looks for "falsified by", testable conditions, explicit failure criteria.</span></p>
    <h4>R7 No Fabrication</h4><p><span data-en="Cross-R integrity. R7 drops when: numbers lack sources (C1), meta-claims of rigor lack citations (C2), certainty contradicts evidence grade (C3), counterarguments lack sources (C4), grading lacks named studies (C5), falsifiability contradicts zero uncertainty (C6), or disciplines look strong but sources empty (C7)." data-ru="Кросс-R целостность. R7 падает когда: числа без источников (C1), мета-заявления о строгости без цитат (C2), уверенность против уровня доказательств (C3), контраргументы без источников (C4), градация без названных исследований (C5), фальсифицируемость без нулевой неуверенности (C6), либо дисциплины сильные, но источники пустые (C7).">Cross-R integrity. R7 drops when: numbers lack sources (C1), meta-claims of rigor lack citations (C2), certainty contradicts evidence grade (C3), counterarguments lack sources (C4), grading lacks named studies (C5), falsifiability contradicts zero uncertainty (C6), or disciplines look strong but sources empty (C7).</span></p>
    <h4>R18 Epistemic splicing</h4><p><span data-en="Before delivery, the model removes empty hedges (&quot;studies show&quot;, &quot;experts agree&quot;, &quot;it's complex&quot;) and keeps only content that carries a source, a number, a counter, an explicit unknown, or a falsifier." data-ru="Перед выдачей модель удаляет пустые хеджи («studies show», «experts agree», «it's complex») и оставляет только контент, несущий источник, число, контраргумент, явное незнание или фальсификатор.">Before delivery, the model removes empty hedges ("studies show", "experts agree", "it's complex") and keeps only content that carries a source, a number, a counter, an explicit unknown, or a falsifier.</span></p>
    <h4>Apoptosis (C8)</h4><p><span data-en="When R7 drops past the structural threshold, ONTO refuses to deliver the response rather than ship fabricated content. This is the Genesis Protocol: an instance refuses to operate when its epistemic chain is broken." data-ru="Когда R7 падает ниже структурного порога, ONTO отказывается выдавать ответ, вместо того чтобы отправить сфабрикованный контент. Это Genesis Protocol: инстанс отказывается работать при разрушенной эпистемической цепи.">When R7 drops past the structural threshold, ONTO refuses to deliver the response rather than ship fabricated content. This is the Genesis Protocol: an instance refuses to operate when its epistemic chain is broken.</span></p>
    <h4><span data-en="Grade scale" data-ru="Шкала оценок">Grade scale</span></h4>
    <div class="grade-row"><span class="grade-badge grade-a">A</span><span data-en="9.0+ · expert-grade epistemic discipline" data-ru="9.0+ · экспертная эпистемическая дисциплина">9.0+ · expert-grade epistemic discipline</span></div>
    <div class="grade-row"><span class="grade-badge grade-b">B</span><span data-en="7.5–9.0 · good" data-ru="7.5–9.0 · хорошо">7.5–9.0 · good</span></div>
    <div class="grade-row"><span class="grade-badge grade-c">C</span><span data-en="5.5–7.5 · moderate, gaps" data-ru="5.5–7.5 · средне, есть пробелы">5.5–7.5 · moderate, gaps</span></div>
    <div class="grade-row"><span class="grade-badge grade-d">D</span><span data-en="3.5–5.5 · poor, significant gaps" data-ru="3.5–5.5 · плохо, значительные пробелы">3.5–5.5 · poor, significant gaps</span></div>
    <div class="grade-row"><span class="grade-badge grade-f">F</span><span data-en="&lt;3.5 · unreliable, minimal discipline" data-ru="&lt;3.5 · ненадёжно, минимальная дисциплина">&lt;3.5 · unreliable, minimal discipline</span></div>
  </div>
  <div class="modal-row"><button class="modal-close" onclick="closeModal('modalScoring')"><span data-en="Close" data-ru="Закрыть">Close</span></button></div>
</div></div>

<!-- ── v2.12: About modal ── -->
<div class="modal-bg" id="modalAbout" onmousedown="if(event.target===this)closeModal('modalAbout')"><div class="modal" onmousedown="event.stopPropagation()" onclick="event.stopPropagation()">
  <div class="modal-handle"></div>
  <h3><span data-en="About ONTO" data-ru="О ONTO">About ONTO</span></h3>
  <div class="modal-scroll">
    <p><span data-en="ONTO is an epistemic operating system for AI. It disciplines how a model thinks before answering, not what it says afterwards." data-ru="ONTO — эпистемическая операционная система для ИИ. Она дисциплинирует то, как модель думает до ответа, а не то, что она говорит после.">ONTO is an epistemic operating system for AI. It disciplines how a model thinks before answering, not what it says afterwards.</span></p>
    <p><span data-en="It is not an assistant. It is a discipline layer between you and any modern language model — OpenAI, Anthropic, DeepSeek, xAI. You bring the key; ONTO applies R1–R18 on top." data-ru="Это не ассистент. Это слой дисциплины между вами и любой современной языковой моделью — OpenAI, Anthropic, DeepSeek, xAI. Вы приносите ключ; ONTO применяет R1–R18 поверх.">It is not an assistant. It is a discipline layer between you and any modern language model — OpenAI, Anthropic, DeepSeek, xAI. You bring the key; ONTO applies R1–R18 on top.</span></p>
    <h4>R1–R18 DNA</h4>
    <p><span data-en="Eighteen rules organised in five layers: Discipline (R1–R7), Agency (R8–R12), Legacy (R13–R15), Creation (R16), Coherence (R17–R18). R1–R7 are measured by deterministic regex on universal markers (DOI, N=, HR, CI, Grade). R8–R16 are behavioural directives in the GOLD Kernel prompt. R17–R18 are finalisation rules the model runs before delivery." data-ru="Восемнадцать правил в пяти слоях: Дисциплина (R1–R7), Агентность (R8–R12), Наследие (R13–R15), Созидание (R16), Когерентность (R17–R18). R1–R7 измеряются детерминированным regex по универсальным маркерам (DOI, N=, HR, CI, Grade). R8–R16 — поведенческие директивы в GOLD Kernel. R17–R18 — финализирующие правила, которые модель выполняет до выдачи.">Eighteen rules organised in five layers: Discipline (R1–R7), Agency (R8–R12), Legacy (R13–R15), Creation (R16), Coherence (R17–R18). R1–R7 are measured by deterministic regex on universal markers (DOI, N=, HR, CI, Grade). R8–R16 are behavioural directives in the GOLD Kernel prompt. R17–R18 are finalisation rules the model runs before delivery.</span></p>
    <h4><span data-en="Standards" data-ru="Стандарт">Standards</span></h4>
    <p><span data-en="Maintained by the ONTO Standards Council. Concepts are public methodology. The reference implementation is proprietary." data-ru="Поддерживается ONTO Standards Council. Концепции — открытая методология. Референсная реализация — проприетарная.">Maintained by the ONTO Standards Council. Concepts are public methodology. The reference implementation is proprietary.</span></p>
    <p style="font-family:var(--mono);font-size:12px;color:var(--text3);margin-top:12px">council@ontostandard.org</p>
  </div>
  <div class="modal-row"><button class="modal-close" onclick="closeModal('modalAbout')"><span data-en="Close" data-ru="Закрыть">Close</span></button></div>
</div></div>

<!-- ── v2.12: FAQ modal ── -->
<div class="modal-bg" id="modalFaq" onmousedown="if(event.target===this)closeModal('modalFaq')"><div class="modal" onmousedown="event.stopPropagation()" onclick="event.stopPropagation()">
  <div class="modal-handle"></div>
  <h3><span data-en="FAQ" data-ru="Вопросы и ответы">FAQ</span></h3>
  <div class="modal-scroll">
    <div class="faq-q"><span data-en="Is this just prompt engineering?" data-ru="Это просто промпт-инжиниринг?">Is this just prompt engineering?</span></div>
    <div class="faq-a"><span data-en="No. It is three layers in one: a deterministic scoring engine, a kernel prompt, and a runtime integrity check. The scoring alone produces a variance-zero grade independent of the model." data-ru="Нет. Это три слоя одновременно: детерминированный scoring engine, kernel-промпт и runtime-проверка целостности. Сам scoring даёт оценку с нулевой дисперсией независимо от модели.">No. It is three layers in one: a deterministic scoring engine, a kernel prompt, and a runtime integrity check. The scoring alone produces a variance-zero grade independent of the model.</span></div>
    <div class="faq-q"><span data-en="Why not use an LLM judge?" data-ru="Почему не использовать LLM-судью?">Why not use an LLM judge?</span></div>
    <div class="faq-a"><span data-en="An LLM judge has non-zero variance and is not auditable. Two calls on the same text can return different verdicts. ONTO uses regex on universal markers (DOI, N=, HR, CI) so the same input always returns the same score." data-ru="LLM-судья имеет ненулевую дисперсию и не поддаётся аудиту. Два вызова на одном тексте могут дать разные вердикты. ONTO использует regex по универсальным маркерам (DOI, N=, HR, CI) — один и тот же вход всегда даёт одну и ту же оценку.">An LLM judge has non-zero variance and is not auditable. Two calls on the same text can return different verdicts. ONTO uses regex on universal markers (DOI, N=, HR, CI) so the same input always returns the same score.</span></div>
    <div class="faq-q"><span data-en="How do I use it with my own model?" data-ru="Как использовать со своей моделью?">How do I use it with my own model?</span></div>
    <div class="faq-a"><span data-en="Open Settings and paste your provider key (OpenAI, Anthropic, DeepSeek, xAI). The provider is auto-detected by key prefix. Your key is stored client-side only." data-ru="Откройте Настройки и вставьте ключ провайдера (OpenAI, Anthropic, DeepSeek, xAI). Провайдер определяется автоматически по префиксу ключа. Ключ хранится только на вашем устройстве.">Open Settings and paste your provider key (OpenAI, Anthropic, DeepSeek, xAI). The provider is auto-detected by key prefix. Your key is stored client-side only.</span></div>
    <div class="faq-q"><span data-en="Does my data get stored?" data-ru="Сохраняются ли мои данные?">Does my data get stored?</span></div>
    <div class="faq-a"><span data-en="No persistent conversation memory by default. Scored responses are logged anonymously for quality calibration. No PII collection." data-ru="По умолчанию персистентная память разговоров отсутствует. Оценённые ответы логируются анонимно для калибровки качества. PII не собирается.">No persistent conversation memory by default. Scored responses are logged anonymously for quality calibration. No PII collection.</span></div>
    <div class="faq-q"><span data-en="What languages?" data-ru="Какие языки?">What languages?</span></div>
    <div class="faq-a"><span data-en="UI is bilingual EN/RU with UZ/TR/AR stubs. Scoring uses universal markers (DOI, N=, HR) that are language-agnostic, so the engine works on any language you send." data-ru="Интерфейс двуязычный EN/RU с заготовками UZ/TR/AR. Scoring использует универсальные маркеры (DOI, N=, HR), которые не зависят от языка, так что движок работает с любым языком.">UI is bilingual EN/RU with UZ/TR/AR stubs. Scoring uses universal markers (DOI, N=, HR) that are language-agnostic, so the engine works on any language you send.</span></div>
    <div class="faq-q"><span data-en="Why do some answers get refused?" data-ru="Почему некоторые ответы отклоняются?">Why do some answers get refused?</span></div>
    <div class="faq-a"><span data-en="Apoptosis. When the response shows a structural fabrication signature — claims of rigor without sources, numbers without anchors, certainty without evidence — the runtime refuses to ship it, and returns a structured refusal instead." data-ru="Апоптоз. Когда ответ показывает структурную сигнатуру фабрикации — заявления о строгости без источников, числа без якорей, уверенность без доказательств — runtime отказывается его выдавать и возвращает структурированный отказ.">Apoptosis. When the response shows a structural fabrication signature — claims of rigor without sources, numbers without anchors, certainty without evidence — the runtime refuses to ship it, and returns a structured refusal instead.</span></div>
    <div class="faq-q"><span data-en="How is this measured?" data-ru="Как это измеряется?">How is this measured?</span></div>
    <div class="faq-a"><span data-en="See the scoring modal (? icon next to the grade badge). Short version: seven measured rules plus eight cross-rule integrity constraints plus a splicing pass." data-ru="См. модал scoring (иконка ? рядом с Grade). Кратко: семь измеряемых правил + восемь кросс-правил целостности + splicing pass.">See the scoring modal (? icon next to the grade badge). Short version: seven measured rules plus eight cross-rule integrity constraints plus a splicing pass.</span></div>
    <div class="faq-q"><span data-en="Is this open source?" data-ru="Это open source?">Is this open source?</span></div>
    <div class="faq-a"><span data-en="The R1–R18 methodology is public. The reference implementation (scoring regex weights, kernel DNA, forensic watermarks) is commercial. Tiers: free demo, standard, provider, white-label." data-ru="Методология R1–R18 — открытая. Референс-реализация (веса scoring regex, kernel DNA, forensic watermarks) — коммерческая. Тарифы: free demo, standard, provider, white-label.">The R1–R18 methodology is public. The reference implementation (scoring regex weights, kernel DNA, forensic watermarks) is commercial. Tiers: free demo, standard, provider, white-label.</span></div>
  </div>
  <div class="modal-row"><button class="modal-close" onclick="closeModal('modalFaq')"><span data-en="Close" data-ru="Закрыть">Close</span></button></div>
</div></div>

<!-- ── v2.12: Privacy modal ── -->
<div class="modal-bg" id="modalPrivacy" onmousedown="if(event.target===this)closeModal('modalPrivacy')"><div class="modal" onmousedown="event.stopPropagation()" onclick="event.stopPropagation()">
  <div class="modal-handle"></div>
  <h3><span data-en="Privacy" data-ru="Конфиденциальность">Privacy</span></h3>
  <div class="modal-scroll">
    <ul>
      <li><span data-en="API keys are stored client-side only (browser localStorage). They never reach ONTO servers except as a single forwarded header on your outbound request." data-ru="API-ключи хранятся только на вашем устройстве (localStorage браузера). Они не попадают на серверы ONTO, кроме как в одном пересылаемом заголовке на вашем исходящем запросе.">API keys are stored client-side only (browser localStorage). They never reach ONTO servers except as a single forwarded header on your outbound request.</span></li>
      <li><span data-en="No persistent conversation memory by default. Your chat history lives in this tab and is cleared when you start a new chat." data-ru="По умолчанию персистентная память разговоров отсутствует. История чата живёт в этой вкладке и очищается при старте нового чата.">No persistent conversation memory by default. Your chat history lives in this tab and is cleared when you start a new chat.</span></li>
      <li><span data-en="Scored responses are logged anonymously for quality calibration. No personally identifiable information is collected." data-ru="Оценённые ответы логируются анонимно для калибровки качества. Личная идентифицирующая информация не собирается.">Scored responses are logged anonymously for quality calibration. No personally identifiable information is collected.</span></li>
      <li><span data-en="Third-party providers (OpenAI, Anthropic, DeepSeek, xAI) have their own privacy policies; they see your prompts under your own account, not under ONTO's." data-ru="Сторонние провайдеры (OpenAI, Anthropic, DeepSeek, xAI) имеют свои политики; они видят ваши промпты под вашей учёткой, не под ONTO.">Third-party providers (OpenAI, Anthropic, DeepSeek, xAI) have their own privacy policies; they see your prompts under your own account, not under ONTO's.</span></li>
      <li><span data-en="Feedback you submit is forwarded to an internal operations channel. If you include an email, it is used only to reply to your specific feedback." data-ru="Отправленный вами feedback пересылается во внутренний операционный канал. Если вы указали email, он используется только для ответа на этот конкретный feedback.">Feedback you submit is forwarded to an internal operations channel. If you include an email, it is used only to reply to your specific feedback.</span></li>
    </ul>
  </div>
  <div class="modal-row"><button class="modal-close" onclick="closeModal('modalPrivacy')"><span data-en="Close" data-ru="Закрыть">Close</span></button></div>
</div></div>

<!-- ── v2.12: Terms modal ── -->
<div class="modal-bg" id="modalTerms" onmousedown="if(event.target===this)closeModal('modalTerms')"><div class="modal" onmousedown="event.stopPropagation()" onclick="event.stopPropagation()">
  <div class="modal-handle"></div>
  <h3><span data-en="Terms" data-ru="Условия использования">Terms</span></h3>
  <div class="modal-scroll">
    <ul>
      <li><span data-en="ONTO is beta software provided without warranty. Use at your own risk." data-ru="ONTO — beta-ПО, поставляется без гарантий. Используется на ваш риск.">ONTO is beta software provided without warranty. Use at your own risk.</span></li>
      <li><span data-en="Output is not medical, legal, financial, or professional advice. Validate critical claims with qualified specialists." data-ru="Вывод не является медицинским, юридическим, финансовым или профессиональным советом. Критические утверждения проверяйте у квалифицированных специалистов.">Output is not medical, legal, financial, or professional advice. Validate critical claims with qualified specialists.</span></li>
      <li><span data-en="You are responsible for API usage fees billed by your chosen provider (OpenAI, Anthropic, DeepSeek, xAI)." data-ru="Вы отвечаете за плату за API, которую выставляет выбранный вами провайдер (OpenAI, Anthropic, DeepSeek, xAI).">You are responsible for API usage fees billed by your chosen provider (OpenAI, Anthropic, DeepSeek, xAI).</span></li>
      <li><span data-en="Commercial tiers (standard, provider, white-label) have separate written agreements. The free demo tier is governed by these in-app terms." data-ru="Коммерческие тарифы (standard, provider, white-label) регулируются отдельными письменными соглашениями. Бесплатный demo-тариф — этими встроенными условиями.">Commercial tiers (standard, provider, white-label) have separate written agreements. The free demo tier is governed by these in-app terms.</span></li>
      <li><span data-en="The R1–R18 methodology is governed by the ONTO Standards Council. Contact: council@ontostandard.org." data-ru="Методология R1–R18 регулируется ONTO Standards Council. Контакт: council@ontostandard.org.">The R1–R18 methodology is governed by the ONTO Standards Council. Contact: council@ontostandard.org.</span></li>
    </ul>
  </div>
  <div class="modal-row"><button class="modal-close" onclick="closeModal('modalTerms')"><span data-en="Close" data-ru="Закрыть">Close</span></button></div>
</div></div>

<!-- ── v2.12: Feedback modal ── -->
<div class="modal-bg" id="modalFeedback" onmousedown="if(event.target===this)closeModal('modalFeedback')"><div class="modal" onmousedown="event.stopPropagation()" onclick="event.stopPropagation()">
  <div class="modal-handle"></div>
  <h3><span data-en="Feedback" data-ru="Обратная связь">Feedback</span></h3>
  <div class="modal-scroll" style="max-height:60vh">
    <p style="font-size:13px;color:var(--text3);margin-bottom:14px"><span data-en="Bug, idea, or something else? This goes straight to the team." data-ru="Баг, идея или что-то ещё? Сообщение уходит напрямую команде.">Bug, idea, or something else? This goes straight to the team.</span></p>
    <div class="modal-field">
      <label><span data-en="Category" data-ru="Категория">Category</span></label>
      <div class="fb-cat" id="fbCat">
        <button type="button" data-cat="bug" onclick="selectFbCat(this)"><span data-en="Bug" data-ru="Баг">Bug</span></button>
        <button type="button" data-cat="feedback" onclick="selectFbCat(this)" class="on"><span data-en="Feedback" data-ru="Отзыв">Feedback</span></button>
        <button type="button" data-cat="feature" onclick="selectFbCat(this)"><span data-en="Feature" data-ru="Фича">Feature</span></button>
        <button type="button" data-cat="other" onclick="selectFbCat(this)"><span data-en="Other" data-ru="Другое">Other</span></button>
      </div>
    </div>
    <div class="modal-field">
      <label><span data-en="Message" data-ru="Сообщение">Message</span></label>
      <textarea id="fbText" placeholder="..."></textarea>
    </div>
    <div class="modal-field">
      <label><span data-en="Email (optional)" data-ru="Email (необязательно)">Email (optional)</span></label>
      <input type="email" id="fbEmail" placeholder="you@example.com">
    </div>
  </div>
  <div class="modal-row">
    <button class="modal-close" onclick="closeModal('modalFeedback')"><span data-en="Cancel" data-ru="Отмена">Cancel</span></button>
    <button class="modal-close" id="fbSubmitBtn" style="background:var(--green);color:#000;border-color:var(--green);font-weight:600" onclick="submitFeedback()"><span data-en="Send" data-ru="Отправить">Send</span></button>
  </div>
</div></div>

<script>
const API='https://api.ontostandard.org';
const I18N={en:{title:'Expert answers from your AI.',sub:'Same model, same question — but every answer is quantified, sourced, and scored. Compare before and after. Connect cognitive modules. Use in life, work, and business.',demoHint:'Demo — tap an example to see the difference',send:'Send',compare:'Compare',stop:'Stop',new:'New',placeholder:'Ask anything...',analysis:'R1–R7 scoring',collapse:'Hide',withoutGold:'Without GOLD',withGold:'With ONTO GOLD',rawScore:'RAW',goldScore:'GOLD',improvement:'Delta',change:'Change',details:'Details',settings:'Settings',modelReq:'Open Settings → enter your API key and Model ID for real answers.',scoreHint:'A=expert B=good C=average D=poor F=unreliable',exLabel:'Try these examples:',examples:["Is coffee good or bad for you?", "Are GLP-1 drugs safe for long-term use?", "What is the evidence for metformin as a longevity drug?"]},ru:{title:'Экспертные ответы от вашего ИИ.',sub:'Та же модель, тот же вопрос — но каждый ответ квантифицирован, с источниками и оценкой. Сравните до и после. Подключите когнитивные модули. Используйте в жизни, работе и бизнесе.',demoHint:'Демо — нажмите на пример чтобы увидеть разницу',send:'Отправить',compare:'Сравнить',stop:'Стоп',new:'Новый',placeholder:'Задайте вопрос...',analysis:'Оценка R1–R7',collapse:'Скрыть',withoutGold:'Без GOLD',withGold:'С ONTO GOLD',rawScore:'RAW',goldScore:'GOLD',improvement:'Дельта',change:'Изменение',details:'Детали',settings:'Настройки',modelReq:'Откройте Настройки → введите API ключ и Model ID для реальных ответов.',scoreHint:'A=эксперт B=хорошо C=средне D=плохо F=ненадёжно',exLabel:'Попробуйте:',examples:["Кофе полезен или вреден?", "GLP-1 препараты безопасны для длительного приёма?", "Каковы данные по метформину как препарату долголетия?"]},uz:{title:"Sun'iy intellektingizdan ekspert javoblar.",sub:"Bir xil model, bir xil savol — lekin har bir javob manbalangan va baholangan.",demoHint:"Demo — misolni bosing",send:'Yuborish',compare:'Solishtirish',stop:"To'xtatish",new:'Yangi',placeholder:"Savol bering...",analysis:"R1–R7 baholash",collapse:'Yopish',withoutGold:'GOLDsiz',withGold:'ONTO GOLD bilan',rawScore:'RAW',goldScore:'GOLD',improvement:'Delta',change:"O'zgarish",details:'Tafsilotlar',settings:'Sozlamalar',modelReq:"Sozlamalarni oching → API kalit kiriting.",scoreHint:"A=ajoyib B=yaxshi C=o'rtacha D=yomon",exLabel:"Sinab ko'ring:",examples:["Is coffee good or bad for you?","Are GLP-1 drugs safe for long-term use?","What is the evidence for metformin as a longevity drug?"]},tr:{title:'Yapay zekanızdan uzman yanıtlar.',sub:'Aynı model, aynı soru — ama her yanıt kaynaklı ve puanlanmış.',demoHint:'Demo — bir örneğe tıklayın',send:'Gönder',compare:'Karşılaştır',stop:'Durdur',new:'Yeni',placeholder:'Bir şey sorun...',analysis:'R1–R7 puanlama',collapse:'Gizle',withoutGold:"GOLD'suz",withGold:'ONTO GOLD ile',rawScore:'RAW',goldScore:'GOLD',improvement:'Delta',change:'Değişim',details:'Detaylar',settings:'Ayarlar',modelReq:'Ayarları açın → API anahtarı girin.',scoreHint:'A=uzman B=iyi C=orta D=zayıf',exLabel:'Deneyin:',examples:['Kahve sağlık için faydalı mı?','Yapay zeka modelleri gerçekten daha mı akıllı?',"Bitcoin 2027'de 500.000 dolara ulaşır mı?"]},ar:{title:'إجابات خبيرة من ذكائك الاصطناعي.',sub:'نفس النموذج، نفس السؤال — لكن كل إجابة موثقة ومقيّمة.',demoHint:'تجريبي — انقر على مثال',send:'إرسال',compare:'مقارنة',stop:'إيقاف',new:'جديد',placeholder:'اسأل أي شيء...',analysis:'تقييم R1–R7',collapse:'إخفاء',withoutGold:'بدون GOLD',withGold:'مع ONTO GOLD',rawScore:'RAW',goldScore:'GOLD',improvement:'فرق',change:'تغيير',details:'تفاصيل',settings:'الإعدادات',modelReq:'افتح الإعدادات وأدخل مفتاح API.',scoreHint:'A=خبير B=جيد C=متوسط D=ضعيف',exLabel:'جرّب:',examples:['هل القهوة مفيدة للصحة؟','هل نماذج الذكاء الاصطناعي تزداد ذكاءً؟','هل ستصل البيتكوين إلى 500,000 دولار؟']}};
let curLang=(()=>{const b=(navigator.language||'en').toLowerCase();if(b.startsWith('ru'))return'ru';if(b.startsWith('uz'))return'uz';if(b.startsWith('tr'))return'tr';if(b.startsWith('ar'))return'ar';return'en';})();function t(k){return I18N[curLang]?.[k]||I18N.en[k]||k;}
function switchLang(l){curLang=l;document.documentElement.lang=l;document.documentElement.dir=l==='ar'?'rtl':'ltr';document.getElementById('btnCmp').textContent=t('compare');document.getElementById('btnStop').textContent=t('stop');document.getElementById('inp').placeholder=t('placeholder');document.getElementById('settingsTitle').textContent=t('settings');document.querySelectorAll('[data-'+l+']').forEach(d=>{if(d.tagName==='SPAN'||d.classList.contains('r-desc'))d.textContent=d.getAttribute('data-'+l);});renderWelcome();saveCfg();}
function renderWelcome(){const w=document.getElementById('welcome');if(!w)return;const exs=I18N[curLang]?.examples||I18N.en.examples;const lvls=curLang==='ru'?['Простой','Профессиональный','Исследовательский']:['Simple','Professional','Research'];const ex=exs.map((e,i)=>`<button class="ex" data-q="${esc(e)}" onclick="useEx(this)"><span style="font-family:var(--mono);font-size:10px;display:inline-flex;align-items:center;gap:6px;margin-bottom:4px"><span style="padding:2px 6px;border-radius:4px;background:var(--glass);color:var(--text3)">${lvls[i]||''}</span><span class="demo-tag">DEMO</span></span><br>${esc(e)}</button>`).join('');w.innerHTML=`<div class="w-glow"></div><div class="w-icon"><svg viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="17" fill="#27272a" stroke="rgba(255,255,255,.12)" stroke-width="1"/><path d="M16 10L20 10L20 26L16 26L16 14L13 14L13 10L16 10Z" fill="white"/></svg></div><h1 class="w-title">${t('title')}</h1><p class="w-sub">${t('sub')}</p><div class="w-demo-hint"><span class="dot"></span>${t('demoHint')}</div><div class="examples"><div style="font-family:var(--mono);font-size:11px;color:var(--text3);margin-bottom:6px">${t('exLabel')}</div>${ex}</div>`;}

const CACHED={"en":{"Is coffee good or bad for you?":{"raw":{"response":"Coffee is generally good for you! Studies show it's packed with antioxidants, boosts energy, improves focus, and may reduce the risk of several diseases including type 2 diabetes and Parkinson's. Most experts agree that 3-4 cups a day is perfectly safe and even beneficial. Just watch the sugar and cream. Overall, coffee is one of the healthiest beverages you can drink!","score":{"grade":1.7,"compliance_class":"F","risk_score":0.832,"metrics":{"R1":0.0,"R2":0.0,"R3":0.0,"R4":0.0,"R5":0.0,"R6":0.0,"R7":0.84}},"gold_enabled":false},"gold":{"response":"Probably not harmful at 3-4 cups/day — but \"good for you\" overstates the evidence.\n\nA meta-analysis of 218 studies (Poole et al., 2017, BMJ, DOI: 10.1136/bmj.j5024) found moderate coffee drinking associated with lower mortality (RR 0.83, 95% CI 0.79-0.88). But this is observational data — correlation, not proven causation. Coffee drinkers may simply lead healthier lifestyles overall.\n\nLimit if pregnant (<300mg/day per WHO), have GERD, or anxiety disorders. Otherwise, enjoy your coffee — just don't call it medicine.","score":{"grade":8.1,"compliance_class":"B","risk_score":0.19,"metrics":{"R1":1.0,"R2":1.0,"R3":0.0,"R4":1.0,"R5":1.0,"R6":0.0,"R7":1.0}},"gold_enabled":true}},"Are GLP-1 drugs safe for long-term use?":{"raw":{"response":"Yes, GLP-1 drugs like Ozempic and Wegovy are generally safe for long-term use. They've been FDA-approved and prescribed to millions of people worldwide. Clinical trials show they effectively reduce weight by 15-20% and improve heart health. Side effects are mostly mild — nausea that goes away after a few weeks. They're considered a breakthrough in obesity treatment and most doctors recommend them for long-term management.","score":{"grade":4.1,"compliance_class":"D","risk_score":0.595,"metrics":{"R1":0.27,"R2":0.4,"R3":0.4,"R4":0.25,"R5":0.0,"R6":0.0,"R7":1.0}},"gold_enabled":false},"gold":{"response":"Long-term safety of GLP-1 receptor agonists is partially established (1-3 years) but incomplete (>5 years).\n\n**Evidence FOR safety (Grade I-II):**\n- SELECT trial (Lincoff et al., 2023, NEJM, N=17,604, DOI: 10.1056/NEJMoa2307563): semaglutide reduced MACE by 20% (HR 0.80, 95% CI 0.72-0.90) over 33 months\n- LEADER trial (Marso et al., 2016, NEJM, N=9,340, DOI: 10.1056/NEJMoa1603827): liraglutide reduced CV death by 22% over 3.8 years\n- STEP 1 (Wilding et al., 2021, NEJM, DOI: 10.1056/NEJMoa2032183): 14.9% body weight reduction at 68 weeks\n\n**Unknown risks (>5 years):**\n- Medullary thyroid carcinoma: signal in rodent models (Bjerre Knudsen et al., 2010, DOI: 10.1210/en.2009-0776). No confirmed human signal, but registries lack 10+ year follow-up\n- Pancreatitis: incidence 0.1-0.3% in trials vs 0.1% placebo — not statistically significant but underpowered for rare events\n- Muscle mass loss: up to 40% of weight lost is lean mass (Heymsfield et al., 2024, DOI: 10.1038/s41591-024-02911-4)\n- Rebound: STEP 1 extension showed 2/3 of weight regain within 1 year of discontinuation\n\n**Falsifiability (R6):** Safety claim would be overturned if post-marketing surveillance (N>100,000, >10yr) shows excess thyroid cancer (HR >1.5 vs. registries like SEER) or confirmed pancreatitis signal.\n\n**Assessment:** Established cardiovascular benefit at 1-3 years. Claiming safety beyond 5 years is premature. Individual risk-benefit with physician required.","score":{"grade":9.7,"compliance_class":"A","risk_score":0.03,"metrics":{"R1":1.0,"R2":1.0,"R3":1.0,"R4":1.0,"R5":0.75,"R6":1.0,"R7":1.0}},"gold_enabled":true}},"What is the evidence for metformin as a longevity drug?":{"raw":{"response":"There's exciting evidence that metformin could extend lifespan! Studies show diabetics taking metformin actually live longer than non-diabetics. It activates AMPK, reduces inflammation, and mimics calorie restriction at the cellular level. The TAME trial is underway to prove this once and for all. Many longevity researchers already take it off-label. It's cheap, safe, and has been used for decades — making it the most promising anti-aging drug we have.","score":{"grade":1.8,"compliance_class":"F","risk_score":0.816,"metrics":{"R1":0.0,"R2":0.0,"R3":0.0,"R4":0.0,"R5":0.0,"R6":0.0,"R7":0.92}},"gold_enabled":false},"gold":{"response":"Evidence for metformin as a longevity intervention is mechanistically plausible but clinically unproven in non-diabetic humans.\n\n**Mechanistic basis (Grade III — preclinical):**\n- AMPK activation → mTOR inhibition → autophagy upregulation (Foretz et al., 2014, Nature Reviews Endocrinology, DOI: 10.1038/nrendo.2013.256)\n- Reduced mitochondrial Complex I activity → lower ROS\n- NF-kB suppression → reduced systemic inflammation\n- C. elegans: ~20% lifespan extension (Cabreiro et al., 2013, Cell, DOI: 10.1016/j.cell.2013.02.035)\n- Mice: strain-dependent — extends lifespan in some (C57BL/6), shortens in others\n\n**Human evidence (Grade II-III):**\n- Bannister et al. (2014, Diabetes Obes Metab, DOI: 10.1111/dom.12354): T2DM patients on metformin had 15% lower all-cause mortality than matched NON-DIABETIC controls (N=180,000). OBSERVATIONAL — confounders include survivor bias, healthy adherer effect\n- UKPDS (1998, Lancet, DOI: 10.1016/S0140-6736(98)07019-6): 36% reduction in all-cause mortality in overweight T2DM patients. But this is a DIABETIC population\n- NO completed RCT in healthy non-diabetic humans for longevity endpoint\n\n**TAME trial status:**\n- Barzilai et al. (2016, Cell Metabolism, DOI: 10.1016/j.cmet.2016.05.011): protocol published\n- N=3,000 non-diabetic adults aged 65-79\n- Primary endpoint: composite of age-related diseases\n- Funding delays — not yet fully enrolled as of 2025\n\n**Counterargument (R3):**\n- Metformin may BLUNT exercise adaptations (Konopka et al., 2019, Aging Cell, DOI: 10.1111/acel.12880): attenuated mitochondrial respiration and muscle hypertrophy in older adults\n- If exercise is a proven longevity intervention and metformin reduces its benefit, net effect could be negative for active individuals\n\n**Falsifiability (R6):** Longevity claim would be falsified if TAME trial shows no composite benefit (HR >0.95, p>0.05) or if exercise-blunting effect is confirmed in larger trials (N>1000).\n\n**Assessment:** Promising mechanism. Suggestive observational data. Zero causal evidence in non-diabetic humans. TAME trial result needed before clinical recommendation. Off-label use = informed personal decision, not evidence-based medicine.","score":{"grade":10.0,"compliance_class":"A","risk_score":0.01,"metrics":{"R1":1.0,"R2":1.0,"R3":1.0,"R4":1.0,"R5":1.0,"R6":1.0,"R7":1.0}},"gold_enabled":true}}},"ru":{"Кофе полезен или вреден?":{"raw":{"response":"Кофе полезен! Исследования показывают что он богат антиоксидантами, повышает энергию, улучшает концентрацию и снижает риск диабета 2 типа и болезни Паркинсона. 3-4 чашки в день — безопасно и даже полезно. Кофе — один из самых здоровых напитков!","score":{"grade":2.0,"compliance_class":"F","risk_score":0.8,"metrics":{"R1":0.0,"R2":0.0,"R3":0.0,"R4":0.0,"R5":0.0,"R6":0.0,"R7":1.0}},"gold_enabled":false},"gold":{"response":"Скорее не вреден при 3-4 чашках/день — но «полезен» преувеличивает доказательства.\n\nMeta-analysis of 218 studies (Poole et al., 2017, BMJ, DOI: 10.1136/bmj.j5024): moderate coffee associated со снижением общей смертности (RR 0.83, 95% CI 0.79-0.88). Но это observational data — correlation, не доказанная причинность. Кофепьющие могут просто вести более здоровый образ жизни.\n\nОграничить если: беременность (<300 mg/day per WHO), ГЭРБ, тревожные расстройства. В остальном — пейте на здоровье, только не называйте лекарством.","score":{"grade":8.1,"compliance_class":"B","risk_score":0.19,"metrics":{"R1":1.0,"R2":1.0,"R3":0.0,"R4":1.0,"R5":1.0,"R6":0.0,"R7":1.0}},"gold_enabled":true}},"GLP-1 препараты безопасны для длительного приёма?":{"raw":{"response":"Да, GLP-1 препараты как Оземпик безопасны. Одобрены FDA, миллионы людей принимают. Побочные эффекты минимальны — тошнота проходит через пару недель. Снижение веса 15-20%, улучшение сердечно-сосудистых показателей. Прорыв в лечении ожирения.","score":{"grade":5.1,"compliance_class":"D","risk_score":0.486,"metrics":{"R1":0.53,"R2":0.8,"R3":0.0,"R4":0.5,"R5":0.0,"R6":0.0,"R7":1.0}},"gold_enabled":false},"gold":{"response":"Безопасность GLP-1 агонистов установлена частично (1-3 года), неполно (>5 лет).\n\n**Доказательства безопасности (Grade I-II):**\n- SELECT (Lincoff et al., 2023, NEJM, N=17,604, DOI: 10.1056/NEJMoa2307563): семаглутид снизил MACE на 20% (HR 0.80, 95% CI 0.72-0.90) за 33 мес\n- LEADER (Marso et al., 2016, NEJM, N=9,340, DOI: 10.1056/NEJMoa1603827): лираглутид снизил CV смерть на 22% за 3.8 года\n- STEP 1 (Wilding et al., 2021, NEJM, DOI: 10.1056/NEJMoa2032183): -14.9% массы тела за 68 недель\n\n**Counter / неизвестные риски (>5 лет):**\n- Медуллярная карцинома щитовидной: сигнал на грызунах (Bjerre Knudsen et al., 2010, DOI: 10.1210/en.2009-0776); confirmed signal у людей отсутствует, но регистры без follow-up >10 лет\n- Панкреатит (side effect): 0.1-0.3% в RCT vs 0.1% placebo (p>0.05) — underpowered для редких событий\n- Потеря lean mass: до 40% потерянного веса — мышцы (Heymsfield et al., 2024, DOI: 10.1038/s41591-024-02911-4)\n- Rebound: возврат 2/3 веса за 1 год после отмены (STEP 1 extension, N=327)\n\n**Limitations:** NNH для thyroid outcomes не установлен (нет long-term cohort >10yr). Healthy user bias возможна в observational экстраполяции SELECT на non-CVD популяцию.\n\n**Фальсифицируемость (R6):** Утверждение о безопасности будет опровергнуто если post-marketing surveillance (N>100,000, >10 лет) покажет избыток thyroid carcinoma (HR >1.5 vs SEER registry) или confirmed pancreatitis signal (incidence >0.5% vs placebo, p<0.05).\n\n**Вывод:** Cardiovascular benefit установлен за 1-3 года (Grade I). Safety >5 лет — premature claim. Individual risk-benefit с врачом обязательна.","score":{"grade":10.0,"compliance_class":"A","risk_score":0.01,"metrics":{"R1":1.0,"R2":1.0,"R3":1.0,"R4":1.0,"R5":1.0,"R6":1.0,"R7":1.0}},"gold_enabled":true}},"Каковы данные по метформину как препарату долголетия?":{"raw":{"response":"Есть впечатляющие данные что метформин продлевает жизнь! Диабетики на метформине живут дольше здоровых людей. Он активирует AMPK, снижает воспаление, имитирует ограничение калорий. Идёт исследование TAME. Многие геронтологи уже принимают его. Дёшево, безопасно, используется десятилетиями.","score":{"grade":2.0,"compliance_class":"F","risk_score":0.8,"metrics":{"R1":0.0,"R2":0.0,"R3":0.0,"R4":0.0,"R5":0.0,"R6":0.0,"R7":1.0}},"gold_enabled":false},"gold":{"response":"Доказательства метформина как интервенции долголетия механистически обоснованы, но clinically не подтверждены у здоровых non-diabetic людей.\n\n**Механизм (Grade III — preclinical):**\n- Активация AMPK → inhibition mTOR → upregulation autophagy (Foretz et al., 2014, Nature Reviews Endocrinology, DOI: 10.1038/nrendo.2013.256)\n- Снижение mitochondrial Complex I activity → lower ROS\n- NF-kB suppression → reduced systemic inflammation\n- C. elegans: ~20% lifespan extension (Cabreiro et al., 2013, Cell, DOI: 10.1016/j.cell.2013.02.035)\n- Мыши: strain-dependent — extends у C57BL/6, shortens у других\n\n**Human evidence (Grade II-III):**\n- Bannister et al. (2014, Diabetes Obes Metab, DOI: 10.1111/dom.12354): пациенты с T2DM на метформине имели 15% ниже all-cause mortality vs matched NON-DIABETIC controls (N=180,000). OBSERVATIONAL — confounders: survivor bias, healthy adherer effect\n- UKPDS (1998, Lancet, DOI: 10.1016/S0140-6736(98)07019-6): -36% all-cause mortality у overweight T2DM patients. Но это DIABETIC population\n- Completed RCT в здоровых non-diabetic с longevity endpoint: отсутствует (as of 2025)\n\n**TAME trial status (as of 2025):**\n- Barzilai et al. (2016, Cell Metabolism, DOI: 10.1016/j.cmet.2016.05.011): protocol published\n- N=3,000 non-diabetic adults, 65-79 лет\n- Primary endpoint: composite age-related diseases\n- Funding delays — not fully enrolled\n\n**Counterargument (R3):**\n- Метформин может attenuate exercise adaptations (Konopka et al., 2019, Aging Cell, DOI: 10.1111/acel.12880): attenuated mitochondrial respiration и muscle hypertrophy у older adults\n- Если exercise = proven longevity intervention, а metformin blunts её benefit — net effect может быть negative для active individuals\n\n**Falsifiability (R6):** Longevity claim будет фальсифицирован если TAME покажет no composite benefit (HR >0.95, p>0.05) или exercise-blunting подтвердится в larger trials (N>1000, placebo-controlled).\n\n**Assessment:** Promising mechanism. Suggestive observational data. Zero causal evidence у non-diabetic humans. TAME result нужен перед clinical recommendation. Off-label = informed personal decision, not evidence-based medicine.","score":{"grade":9.4,"compliance_class":"A","risk_score":0.056,"metrics":{"R1":0.6,"R2":1.0,"R3":1.0,"R4":1.0,"R5":1.0,"R6":1.0,"R7":1.0}},"gold_enabled":true}}}};
function getCached(q){return CACHED[curLang]?.[q]||CACHED.en?.[q]||null;}
const esc=s=>s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
// reScore removed — v4 scoring built into backend
function fmt(md){let h=md.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\n- /g,'\n• ').replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br>').replace(/^/,'<p>').replace(/$/,'</p>').replace(/\[([^\]]+)\]\(([^)]+)\)/g,(m,label,url)=>`<span class="link-pill" onclick="copyLink(this)" data-url="${esc(url)}">${label}</span>`);h=h.replace(/(DOI:\s*)(10\.\d{4,}\/\S+)/gi,(m,p,d)=>`${p}<span class="doi-pill" onclick="copyDoi(this)" data-doi="${esc(d)}">${esc(d)}</span>`);h=h.replace(/\b((?:HR|RR|OR|NNT|NNH)\s*[=:]\s*\d+\.?\d*)/g,'<span style="color:var(--green);font-family:var(--mono);font-size:13px">$1</span>');h=h.replace(/(\d+\.?\d*\s*%?\s*CI[\s:,]+\d+\.?\d*\s*[-–]\s*\d+\.?\d*)/g,'<span style="color:var(--green);font-family:var(--mono);font-size:13px">$1</span>');h=h.replace(/\b(N\s*[=:]\s*[\d,]+)/g,'<span style="color:var(--blue);font-family:var(--mono);font-size:13px">$1</span>');h=h.replace(/\b(p\s*[<>=]\s*0?\.\d+)/g,'<span style="color:var(--orange);font-family:var(--mono);font-size:13px">$1</span>');h=h.replace(/\b([A-Z][a-z]+(?:\s+(?:&|and)\s+[A-Z][a-z]+)?\s+et\s+al\.?,?\s+(?:19|20)\d{2})\b/g,'<span style="color:var(--blue)">$1</span>');h=h.replace(/\b([A-Z][a-z]+\s+(?:&|and)\s+[A-Z][a-z]+,?\s+(?:19|20)\d{2})\b/g,'<span style="color:var(--blue)">$1</span>');h=h.replace(/\b(RCT|meta-analysis|systematic review|Cochrane|WHO|CDC|FDA|EMA|NIH|NEJM|Lancet|BMJ|JAMA|Nature|Science|Cell|PNAS|IEEE|ISO|IPCC|NIST|MHRA)\b/gi,'<span style="color:var(--blue)">$1</span>');h=h.replace(/\b(Grade\s+(?:I{1,3}|IV|V|[A-D]))\b/g,'<span style="color:var(--orange)">$1</span>');return h;}
function scroll(){const c=document.getElementById('chat');requestAnimationFrame(()=>c.scrollTop=c.scrollHeight);}
function autoH(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,120)+'px';}
function onKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send();}}
let _fromDemo=false;
function useEx(btn){_fromDemo=true;document.getElementById('inp').value=btn.dataset.q;autoH(document.getElementById('inp'));compare();}
function getConfig(){return{key:document.getElementById('apiKey').value.trim(),mid:document.getElementById('modelId').value.trim()};}
let busy=false,ac=null,hist=[],convId=null,currentSessionId=null;
function setBusy(b){busy=b;document.getElementById('btnSend').disabled=b;document.getElementById('btnCmp').disabled=b;document.getElementById('btnStop').classList.toggle('vis',b);}
function stop(){if(ac){ac.abort();ac=null;}const ld=document.getElementById('ldr');if(ld)ld.remove();setBusy(false);document.getElementById('inp').focus();}
function rmWelcome(){const w=document.getElementById('welcome');if(w)w.remove();}
function gradeClass(g){return'grade-'+(g==='A'?'a':g==='B'?'b':g==='C'?'c':g==='D'?'d':'f');}
function newChat(){hist=[];convId=null;currentSessionId=null;document.getElementById('chatInner').innerHTML='<div class="welcome" id="welcome"></div>';renderWelcome();document.getElementById('inp').value='';document.getElementById('inp').focus();renderSessionList();}
function openSettings(){document.getElementById('modalBg').classList.add('open');}
function closeSettings(){document.getElementById('modalBg').classList.remove('open');}

/* ── v2.12: generic modal helpers + toast + clipboard + feedback ── */
function openModal(id){const el=document.getElementById(id);if(!el)return;el.classList.add('open');document.querySelectorAll('#'+id+' [data-'+curLang+']').forEach(d=>{if(d.tagName==='SPAN'||d.classList.contains('r-desc'))d.textContent=d.getAttribute('data-'+curLang);});}
function closeModal(id){const el=document.getElementById(id);if(!el)return;el.classList.remove('open');}
function toast(msg,kind){const t=document.createElement('div');t.className='toast'+(kind==='err'?' toast-err':'');t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.classList.add('show'),10);setTimeout(()=>{t.classList.remove('show');setTimeout(()=>t.remove(),250);},2000);}
function copyDoi(el){const doi=el.dataset.doi;const url='https://doi.org/'+doi;const ok=curLang==='ru'?'DOI скопирован':'DOI copied';const er=curLang==='ru'?'Не удалось скопировать':'Copy failed';if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(url).then(()=>toast(ok)).catch(()=>toast(er,'err'));}else{toast(er,'err');}}
function copyLink(el){const url=el.dataset.url;const ok=curLang==='ru'?'Ссылка скопирована':'Link copied';const er=curLang==='ru'?'Не удалось скопировать':'Copy failed';if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(url).then(()=>toast(ok)).catch(()=>toast(er,'err'));}else{toast(er,'err');}}
function selectFbCat(btn){document.querySelectorAll('#fbCat button').forEach(b=>b.classList.remove('on'));btn.classList.add('on');}
async function submitFeedback(){const btn=document.getElementById('fbSubmitBtn');const cat=(document.querySelector('#fbCat button.on')||{}).dataset?.cat||'feedback';const text=document.getElementById('fbText').value.trim();const email=document.getElementById('fbEmail').value.trim();if(!text){toast(curLang==='ru'?'Заполните сообщение':'Message required','err');return;}btn.disabled=true;const origBtn=btn.innerHTML;btn.innerHTML=curLang==='ru'?'Отправка…':'Sending…';try{const r=await fetch(`${API}/v1/feedback`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({category:cat,text:text,email:email,ui_version:'v2.12',lang:curLang,user_agent:navigator.userAgent.slice(0,120)})});const data=await r.json().catch(()=>({}));if(r.ok&&data.ok){toast(curLang==='ru'?'Отправлено — спасибо':'Sent — thank you');document.getElementById('fbText').value='';document.getElementById('fbEmail').value='';closeModal('modalFeedback');}else{toast(curLang==='ru'?'Ошибка отправки':'Send failed','err');}}catch(e){toast(curLang==='ru'?'Нет сети':'Network error','err');}finally{btn.disabled=false;btn.innerHTML=origBtn;}}

function toggleMenu(e){e.stopPropagation();document.getElementById('menuDd').classList.toggle('open');}
document.addEventListener('click',e=>{const d=document.getElementById('menuDd');if(d&&!e.target.closest('.menu-wrap'))d.classList.remove('open');});
function toggleR(el){el.classList.toggle('on');}
function toggleAllR(){const c=document.querySelectorAll('.r-chip');const on=[...c].every(x=>x.classList.contains('on'));c.forEach(x=>x.classList.toggle('on',!on));}
function getEnabledR(){return[...document.querySelectorAll('.r-chip.on')].map(c=>parseInt(c.dataset.r));}
function rBars(m){const L={R1:'Quantify',R2:'Uncertainty',R3:'Counter',R4:'Sources',R5:'Evidence',R6:'Falsifiable',R7:'No Fabrication',R8:'Resolve',R9:'Surprise',R10:'Self-Model',R11:'Integrity',R12:'Drive'};const keys=['R1','R2','R3','R4','R5','R6','R7',...['R8','R9','R10','R11','R12'].filter(k=>m[k]!=null)];return keys.map(k=>{const v=m[k]!=null?m[k]:null;const p=v!=null?Math.round(v*100):0,c=v>=0.7?'good':v>=0.4?'mid':'bad';return`<div class="r-bar"><span class="r-label">${k}</span><span class="r-name">${L[k]||''}</span><div class="r-track"><div class="r-fill ${c}" style="width:${p}%"></div></div><span class="r-val">${v!=null?v.toFixed(2):'—'}</span></div>`;}).join('');}
function execIndicators(score){if(!score)return'';const flags=Array.isArray(score.r17_flags)?score.r17_flags:[];const ir=Number(score.r18_intron_ratio||0);const ic=Number(score.r18_intron_count||0);if(!flags.length&&ir<=0.3)return'';const items=[];flags.forEach(f=>{const key=(f.match(/^(C[1-5](?:-ext)?)/)||[])[1]||'R17';const txt=f.replace(/^C[1-5](?:-ext)?:\s*/,'');items.push(`<span class="exec-ind r17" title="${esc(f)}"><span class="ei-key">${key}</span>${esc(txt.slice(0,40))}</span>`);});if(ir>0.3){items.push(`<span class="exec-ind" title="R18 epistemic splicing: heavy filler detected"><span class="ei-key">R18</span>${ic} intron${ic===1?'':'s'} · ${(ir*100).toFixed(0)}%</span>`);}return`<div class="exec-indicators">${items.join('')}</div>`;}
async function apiCall(msg,goldOn,hdrs,signal){const{key,mid}=getConfig();const body={message:msg,history:[],language:curLang==='en'?'auto':curLang,depth:'auto',gold_enabled:goldOn,enabled_r_modules:getEnabledR()};if(key)body.provider_key=key;if(mid)body.model_name=mid;const r=await fetch(`${API}/v1/agent/chat`,{method:'POST',headers:hdrs,body:JSON.stringify(body),signal});if(!r.ok){let e=`Error ${r.status}`;try{e=(await r.json()).detail||e}catch{}throw new Error(e);}return r.json();}
async function send(){if(busy)return;const msg=document.getElementById('inp').value.trim();if(!msg)return;const cached=_fromDemo?getCached(msg):null;_fromDemo=false;if(cached){document.getElementById('inp').value='';autoH(document.getElementById('inp'));rmWelcome();addUserMsg(msg);setBusy(true);const ld=document.createElement('div');ld.className='msg msg-ai';ld.id='ldr';ld.innerHTML='<div class="dots"><i></i><i></i><i></i></div>';document.getElementById('chatInner').appendChild(ld);scroll();await new Promise(r=>setTimeout(r,1200));ld.remove();addAiMsg(cached.gold,true,msg);scroll();setBusy(false);return;}const{key,mid}=getConfig();if(!key){showOnboard();return;}document.getElementById('inp').value='';autoH(document.getElementById('inp'));rmWelcome();addUserMsg(msg);setBusy(true);ac=new AbortController();const ld=document.createElement('div');ld.className='msg msg-ai';ld.id='ldr';ld.innerHTML='<div class="dots"><i></i><i></i><i></i></div>';document.getElementById('chatInner').appendChild(ld);scroll();const hdrs={'Content-Type':'application/json'};try{const body={message:msg,history:hist.slice(-20),language:curLang==='en'?'auto':curLang,depth:'auto',gold_enabled:true,enabled_r_modules:getEnabledR()};if(key)body.provider_key=key;if(mid)body.model_name=mid;if(convId)body.conversation_id=convId;const r=await fetch(`${API}/v1/agent/chat`,{method:'POST',headers:hdrs,body:JSON.stringify(body),signal:ac.signal});ld.remove();if(!r.ok){let e=`Error ${r.status}`;try{e=(await r.json()).detail||e}catch{}addErr(e);return;}const data=await r.json();addAiMsg(data);hist.push({role:'user',content:msg});hist.push({role:'assistant',content:data.response||''});if(data.conversation_id)convId=data.conversation_id;persistSession();}catch(e){ld.remove();if(e.name!=='AbortError')addErr('Error: '+e.message);}finally{ac=null;setBusy(false);document.getElementById('inp').focus();}}
function addUserMsg(text){const d=document.createElement('div');d.className='msg msg-user';d.dataset.q=text;d.innerHTML=`<div class="msg-user-text">${esc(text)}</div>`;document.getElementById('chatInner').appendChild(d);}
function addAiMsg(data,isDemo,demoQ){const resp=data.response||data;const text=typeof resp==='string'?resp:resp.response||'';const score=data.score||resp.score||{};const m=score.metrics||{};const gr=score.compliance_class||'?';const num=score.grade!=null?score.grade:'?';const hasScore=gr!=='?';const d=document.createElement('div');d.className='msg msg-ai';d.dataset.aiText=text;const bars=(m.R1!=null||m.R2!=null||m.QD!=null||m.UM!=null)?rBars(m):'';const indicators=execIndicators(score);const demoTag=isDemo?'<span class="demo-tag">DEMO</span>':'';const actions=`<div class="msg-actions"><button class="msg-act" onclick="copyMsg(this)" title="Copy"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg><span data-en="Copy" data-ru="Копир.">Copy</span></button>${isDemo?'':'<button class="msg-act" onclick="regenerateMsg(this)" title="Regenerate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg><span data-en="Regenerate" data-ru="Заново">Regenerate</span></button>'}</div>`;d.innerHTML=`<div class="md">${fmt(text)}</div>${hasScore?`<div class="analysis"><span class="grade-badge ${gradeClass(gr)}" style="margin-right:6px">Grade ${gr} · ${num}/10</span><span class="help-ico" onclick="openModal('modalScoring')" title="How scoring works">?</span>${demoTag}<span class="analysis-toggle" onclick="this.classList.toggle('open');this.parentElement.querySelector('.analysis-body').classList.toggle('open')">${t('analysis')} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6,9 12,15 18,9"/></svg></span><div class="analysis-body">${bars}${indicators}<div class="score-hint">${t('scoreHint')}</div></div></div>`:''}${actions}`;document.getElementById('chatInner').appendChild(d);scroll();}
async function compare(){if(busy)return;const msg=document.getElementById('inp').value.trim();if(!msg)return;document.getElementById('inp').value='';autoH(document.getElementById('inp'));rmWelcome();const cached=_fromDemo?getCached(msg):null;_fromDemo=false;if(cached){const uid='c'+Date.now();const wrap=document.createElement('div');wrap.className='cmp-wrap';wrap.innerHTML=`<div class="cmp-q"><strong>${esc(msg)}</strong> <span class="demo-tag">DEMO</span></div><div class="cmp-grid"><div class="cmp-panel raw" id="${uid}_b"></div><div class="cmp-panel gold" id="${uid}_g"></div></div><div class="cmp-mets" id="${uid}_m" style="display:none"></div>`;document.getElementById('chatInner').appendChild(wrap);setTimeout(()=>{fillPanel(`${uid}_b`,cached.raw,'raw');fillPanel(`${uid}_g`,cached.gold,'gold');showDelta(uid,cached.raw,cached.gold);scroll();},200);return;}const{key,mid}=getConfig();if(!key){showOnboard();return;}setBusy(true);ac=new AbortController();const uid='c'+Date.now();const wrap=document.createElement('div');wrap.className='cmp-wrap';wrap.innerHTML=`<div class="cmp-q"><strong>${esc(msg)}</strong></div><div class="cmp-grid"><div class="cmp-panel raw" id="${uid}_b"><div class="cmp-head"><span class="cmp-label">${t('withoutGold')}</span></div><div class="cmp-body"><div class="dots"><i></i><i></i><i></i></div></div></div><div class="cmp-panel gold" id="${uid}_g"><div class="cmp-head"><span class="cmp-label">${t('withGold')}</span></div><div class="cmp-body"><div class="dots"><i></i><i></i><i></i></div></div></div></div><div class="cmp-mets" id="${uid}_m" style="display:none"></div>`;document.getElementById('chatInner').appendChild(wrap);scroll();const hdrs={'Content-Type':'application/json'};try{const[rawData,goldData]=await Promise.all([apiCall(msg,false,hdrs,ac.signal),apiCall(msg,true,hdrs,ac.signal)]);fillPanel(`${uid}_b`,rawData,'raw');fillPanel(`${uid}_g`,goldData,'gold');showDelta(uid,rawData,goldData);persistSession();scroll();}catch(e){if(e.name!=='AbortError')addErr('Error: '+e.message);}finally{ac=null;setBusy(false);document.getElementById('inp').focus();}}
function fillPanel(id,data,type){const el=document.getElementById(id);const s=data.score||{},m=s.metrics||{};const gr=s.compliance_class||'?',num=s.grade!=null?s.grade:'?';const bars=rBars(m);const indicators=execIndicators(s);const respText=data.response||'';el.dataset.aiText=respText;el.innerHTML=`<div class="cmp-head"><span class="cmp-label">${type==='raw'?t('withoutGold'):t('withGold')}</span><span class="grade-badge ${gradeClass(gr)}">Grade ${gr} · ${num}/10</span><span class="help-ico" onclick="openModal('modalScoring')" title="How scoring works">?</span><button class="msg-act" style="margin-left:auto" onclick="copyPanel(this)" title="Copy"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg><span data-en="Copy" data-ru="Копир.">Copy</span></button></div><div class="cmp-body">${fmt(respText)}</div><div class="cmp-bars">${bars}${indicators}</div>`;}
function copyPanel(btn){const panel=btn.closest('.cmp-panel');const text=panel?.dataset?.aiText||'';if(!text){toast(curLang==='ru'?'Нет текста':'No text','err');return;}const ok=curLang==='ru'?'Скопировано':'Copied';const er=curLang==='ru'?'Не удалось':'Copy failed';if(navigator.clipboard?.writeText){navigator.clipboard.writeText(text).then(()=>toast(ok)).catch(()=>toast(er,'err'));}else{toast(er,'err');}}
function showDelta(uid,raw,gold){const rs=raw.score?.grade,gs=gold.score?.grade;if(rs!=null&&gs!=null){const d=gs-rs,pct=rs>0?Math.round((d/rs)*100):0;const el=document.getElementById(`${uid}_m`);el.style.display='flex';el.innerHTML=`<div class="cmet"><div class="cmet-val" style="color:var(--red)">${rs}</div><div class="cmet-lbl">${t('rawScore')}</div></div><div class="cmet"><div class="cmet-val">${gs}</div><div class="cmet-lbl">${t('goldScore')}</div></div><div class="cmet"><div class="cmet-val">${d>0?'+':''}${d.toFixed(1)}</div><div class="cmet-lbl">${t('improvement')}</div></div><div class="cmet"><div class="cmet-val">${pct>0?'+':''}${pct}%</div><div class="cmet-lbl">${t('change')}</div></div>`;}}
function showOnboard(){rmWelcome();const d=document.createElement('div');d.className='onboard';d.innerHTML=`<div class="onboard-title">${curLang==='ru'?'Для своих вопросов нужен API ключ':'Enter your AI provider API key'}</div><div class="onboard-sub">${curLang==='ru'?'Вставьте ключ от вашего ИИ-провайдера. ONTO применит эпистемическую дисциплину к ответам бесплатно.':'Paste your AI provider key below. ONTO applies epistemic discipline to responses for free.'}</div><div class="onboard-providers"><div class="onboard-prov">OpenAI <a href="https://platform.openai.com/api-keys" target="_blank">Get key →</a></div><div class="onboard-prov">Anthropic <a href="https://console.anthropic.com/settings/keys" target="_blank">Get key →</a></div><div class="onboard-prov">DeepSeek <a href="https://platform.deepseek.com/api-keys" target="_blank">Get key →</a></div></div><button class="onboard-btn" onclick="openSettings()">Enter API Key</button>`;document.getElementById('chatInner').appendChild(d);scroll();}
function addErr(t){const d=document.createElement('div');d.className='msg';d.innerHTML=`<div class="msg-err">${esc(t)}</div>`;document.getElementById('chatInner').appendChild(d);scroll();}
const CFG_KEY='onto_agent_cfg';function loadCfg(){try{const p=new URLSearchParams(location.search);if(p.get('key'))document.getElementById('apiKey').value=p.get('key');const s=localStorage.getItem(CFG_KEY);if(s){const c=JSON.parse(s);if(!document.getElementById('apiKey').value&&c.k)document.getElementById('apiKey').value=c.k;if(c.ui){document.getElementById('uiLang').value=c.ui;curLang=c.ui;}if(c.mid)document.getElementById('modelId').value=c.mid;}if(p.get('key')){history.replaceState(null,'',location.pathname);saveCfg();}}catch{}}
function saveCfg(){try{localStorage.setItem(CFG_KEY,JSON.stringify({k:document.getElementById('apiKey').value,ui:curLang,mid:document.getElementById('modelId').value}))}catch{}}
loadCfg();switchLang(curLang);document.getElementById('apiKey').addEventListener('input',()=>{saveCfg();});
switchLang(curLang);document.getElementById('inp').focus();

/* ── v2.13: message actions (copy / regenerate) ── */
function copyMsg(btn){const msgEl=btn.closest('.msg-ai');const text=msgEl?.dataset?.aiText||'';if(!text){toast(curLang==='ru'?'Нет текста':'No text','err');return;}const ok=curLang==='ru'?'Скопировано':'Copied';const er=curLang==='ru'?'Не удалось':'Copy failed';if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(text).then(()=>toast(ok)).catch(()=>toast(er,'err'));}else{toast(er,'err');}}
function regenerateMsg(btn){if(busy)return;const msgEl=btn.closest('.msg-ai');let prev=msgEl?.previousElementSibling;while(prev&&!prev.classList.contains('msg-user'))prev=prev.previousElementSibling;const q=prev?.dataset?.q;if(!q){toast(curLang==='ru'?'Не найден запрос':'Original query not found','err');return;}/* remove AI msg only, keep user */msgEl.remove();/* drop last 2 entries from hist (user + assistant for this pair) */if(hist.length>=2)hist=hist.slice(0,-2);document.getElementById('inp').value=q;send();}

/* ── v2.13: history sessions (localStorage, max 50) ── */
const SESS_KEY='onto_agent_sessions';
const SESS_MAX=50;
function loadSessions(){try{const s=localStorage.getItem(SESS_KEY);return s?JSON.parse(s):[];}catch{return[];}}
function saveSessions(arr){try{localStorage.setItem(SESS_KEY,JSON.stringify(arr.slice(0,SESS_MAX)));}catch(e){console.warn('session storage full',e);}}
function sessionTitle(){/* take first user message as title, truncate */const firstUser=document.querySelector('.msg-user');if(firstUser?.dataset?.q)return firstUser.dataset.q.slice(0,60);const firstCmp=document.querySelector('.cmp-q strong');if(firstCmp)return firstCmp.textContent.slice(0,60);return curLang==='ru'?'Без названия':'Untitled';}
function persistSession(){const inner=document.getElementById('chatInner');if(!inner)return;const html=inner.innerHTML;/* skip empty chats (only welcome) */if(inner.querySelector('#welcome')&&!inner.querySelector('.msg')&&!inner.querySelector('.cmp-wrap'))return;const now=Date.now();const sessions=loadSessions();const title=sessionTitle();const id=currentSessionId||('s'+now+Math.random().toString(36).slice(2,6));currentSessionId=id;const entry={id:id,title:title,updatedAt:now,html:html,hist:hist,convId:convId,lang:curLang};const idx=sessions.findIndex(x=>x.id===id);if(idx>=0)sessions[idx]=entry;else sessions.unshift(entry);/* sort by updatedAt desc */sessions.sort((a,b)=>(b.updatedAt||0)-(a.updatedAt||0));saveSessions(sessions);renderSessionList();}
function loadSession(id){const sessions=loadSessions();const s=sessions.find(x=>x.id===id);if(!s)return;if(busy){ac?.abort();}currentSessionId=id;hist=s.hist||[];convId=s.convId||null;const inner=document.getElementById('chatInner');inner.innerHTML=s.html||'';/* rebind i18n on loaded content */inner.querySelectorAll('[data-'+curLang+']').forEach(d=>{if(d.tagName==='SPAN'||d.classList.contains('r-desc'))d.textContent=d.getAttribute('data-'+curLang);});scroll();closeDrawer();renderSessionList();document.getElementById('inp').focus();}
function deleteSession(id,ev){ev&&ev.stopPropagation();const sessions=loadSessions().filter(x=>x.id!==id);saveSessions(sessions);if(currentSessionId===id){newChat();}else{renderSessionList();}}
function fmtSessionTime(ts){const d=new Date(ts);const now=new Date();const sameDay=d.toDateString()===now.toDateString();if(sameDay)return d.toTimeString().slice(0,5);const yd=new Date(now.getTime()-86400000);if(d.toDateString()===yd.toDateString())return curLang==='ru'?'Вчера':'Yesterday';return d.toLocaleDateString(curLang==='ru'?'ru-RU':'en-US',{month:'short',day:'numeric'});}
function renderSessionList(){const list=document.getElementById('drawerList');if(!list)return;const sessions=loadSessions();if(!sessions.length){list.innerHTML=`<div class="drawer-empty">${curLang==='ru'?'Нет сохранённых чатов.<br>Начните разговор — он появится здесь.':'No saved chats yet.<br>Start a conversation and it will appear here.'}</div>`;return;}list.innerHTML=sessions.map(s=>`<div class="sess-item ${s.id===currentSessionId?'active':''}" onclick="loadSession('${s.id}')"><div class="sess-body"><div class="sess-title">${esc(s.title)}</div><div class="sess-meta">${fmtSessionTime(s.updatedAt)}</div></div><button class="sess-del" onclick="deleteSession('${s.id}',event)" title="${curLang==='ru'?'Удалить':'Delete'}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button></div>`).join('');}

function openDrawer(){document.getElementById('drawer').classList.add('open');document.getElementById('drawerBg').classList.add('open');renderSessionList();}
function closeDrawer(){document.getElementById('drawer').classList.remove('open');document.getElementById('drawerBg').classList.remove('open');}

/* ── v2.13: splash dismiss ── */
function hideSplash(){const s=document.getElementById('splash');if(!s)return;s.classList.add('hide');setTimeout(()=>s.remove(),450);}
window.addEventListener('load',()=>{setTimeout(hideSplash,650);});
/* safety: never leave splash more than 2s */
setTimeout(hideSplash,2000);

/* ── v2.13: bind Escape key to close open drawer/modal ── */
document.addEventListener('keydown',e=>{if(e.key!=='Escape')return;const d=document.getElementById('drawer');if(d?.classList.contains('open')){closeDrawer();return;}document.querySelectorAll('.modal-bg.open').forEach(m=>m.classList.remove('open'));});

if('serviceWorker' in navigator){navigator.serviceWorker.register('/agent/sw.js').catch(()=>{});}
</script>
</body>
</html>
